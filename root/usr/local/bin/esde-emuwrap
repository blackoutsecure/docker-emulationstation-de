#!/usr/bin/env bash
# esde-emuwrap — Generic emulator wrapper for sidecar-provisioned binaries.
#
# ES-DE launches emulators by name (e.g., retroarch, ppsspp, dolphin-emu).
# This script is symlinked as the emulator name on PATH.  It resolves the
# emulator from argv[0] (the symlink name), finds the sidecar-provisioned
# binary under /opt/emulators/<name>/, sets LD_LIBRARY_PATH to isolate
# bundled libraries, then exec's the real binary.
#
# Supported emulators (any that ES-DE can launch):
#   - RetroArch  https://docs.linuxserver.io/images/docker-retroarch/
#   - (extensible to PPSSPP, Dolphin, PCSX2, Flycast, melonDS, etc.)
set -euo pipefail

EMULATORS_HOME="${ESDE_EMULATORS_HOME:-/opt/emulators}"

# Resolve emulator name from how we were invoked (symlink name)
EMU_NAME="$(basename "$0")"
EMU_HOME="${EMULATORS_HOME}/${EMU_NAME}"
EMU_BIN="${EMU_HOME}/bin/${EMU_NAME}"
EMU_LIBS="${EMU_HOME}/lib"

TAG="[esde-emuwrap:${EMU_NAME}]"

if [[ ! -x "${EMU_BIN}" ]]; then
  echo "" >&2
  echo "${TAG} ================================================" >&2
  echo "${TAG} ERROR: ${EMU_NAME} not found at ${EMU_BIN}" >&2
  echo "${TAG} " >&2
  if [[ -d "${EMU_HOME}" ]]; then
    if [[ -f "${EMU_HOME}/VERSION" ]]; then
      echo "${TAG} Volume exists with VERSION: $(cat "${EMU_HOME}/VERSION")" >&2
      echo "${TAG} but the binary is missing or not executable." >&2
      echo "${TAG} The emulator-provider sidecar may need to re-run:" >&2
    else
      echo "${TAG} Directory ${EMU_HOME} exists but appears empty." >&2
      echo "${TAG} The emulator-provider sidecar has not run yet." >&2
    fi
  elif [[ -d "${EMULATORS_HOME}" ]]; then
    echo "${TAG} Emulators volume ${EMULATORS_HOME} exists but ${EMU_NAME}/ not found." >&2
    echo "${TAG} The sidecar for ${EMU_NAME} may not have been provisioned." >&2
    _available="$(ls "${EMULATORS_HOME}" 2>/dev/null | tr '\n' ' ')" || true
    if [[ -n "${_available}" ]]; then
      echo "${TAG} Currently provisioned: ${_available}" >&2
    fi
  else
    echo "${TAG} Emulators volume ${EMULATORS_HOME} does not exist." >&2
    echo "${TAG} Ensure the esde-emulators volume is mounted." >&2
  fi
  echo "${TAG} " >&2
  echo "${TAG} To fix, start the sidecar:" >&2
  echo "${TAG}   docker compose --profile sidecar up esde-emulator-provider" >&2
  echo "${TAG} " >&2
  echo "${TAG} Or build the emulator into the image:" >&2
  echo "${TAG}   docker compose build --build-arg INSTALL_RETROARCH=true" >&2
  echo "${TAG} " >&2
  echo "${TAG} Supported emulators:" >&2
  echo "${TAG}   RetroArch: https://docs.linuxserver.io/images/docker-retroarch/" >&2
  echo "${TAG} ================================================" >&2
  echo "" >&2
  exit 127
fi

# Prepend sidecar libs so the emulator uses its own bundled versions.
# Append existing LD_LIBRARY_PATH so system libs (GL, ALSA, etc.) are still found.
if [[ -d "${EMU_LIBS}" ]]; then
  export LD_LIBRARY_PATH="${EMU_LIBS}${LD_LIBRARY_PATH:+:${LD_LIBRARY_PATH}}"
fi

# RetroArch-specific: set core directory if available
if [[ "${EMU_NAME}" == "retroarch" && -d "${EMU_HOME}/cores" ]]; then
  export LIBRETRO_DIRECTORY="${EMU_HOME}/cores"
fi

exec "${EMU_BIN}" "$@"
