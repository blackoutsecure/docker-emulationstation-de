#!/usr/bin/env python3
"""esde-local-input — Forward local keyboard/mouse input to the Xvfb display.

Reads from physical /dev/input/event* devices (keyboards, mice) and injects
events into the virtual X display via the XTEST extension.  This allows
local USB keyboards and mice to control ES-DE when using HDMI mirror output.

Gamepads are NOT forwarded — SDL2 reads them directly from /dev/input/.

Environment:
  LOCAL_INPUT       Set to 'true' to enable (checked by svc-local-input)
  DISPLAY           X display to inject into (default: :1)
  LOCAL_INPUT_GRAB  'false' to disable exclusive device grab (default: true)
"""

import logging
import os
import select
import signal
import sys
import time

log = logging.getLogger("local-input")
logging.basicConfig(
    level=logging.INFO,
    format="[local-input] %(message)s",
    stream=sys.stdout,
)

try:
    import evdev
    from evdev import InputDevice, ecodes, list_devices
except ImportError:
    log.error("python3-evdev not installed. Run: apt install python3-evdev")
    sys.exit(1)

try:
    from Xlib import X
    from Xlib import display as xdisplay
    from Xlib.ext import xtest
except ImportError:
    log.error("python3-xlib not installed. Run: apt install python3-xlib")
    sys.exit(1)

# X11 keycode = evdev keycode + 8 (standard xkb evdev offset)
EVDEV_X11_OFFSET = 8

# Evdev button code -> X11 button number
BUTTON_MAP = {
    ecodes.BTN_LEFT: 1,
    ecodes.BTN_MIDDLE: 2,
    ecodes.BTN_RIGHT: 3,
    ecodes.BTN_SIDE: 8,
    ecodes.BTN_EXTRA: 9,
}

# Gamepad button codes used to identify (and skip) gamepad devices
_GAMEPAD_BTNS = {
    getattr(ecodes, n)
    for n in (
        "BTN_A", "BTN_B", "BTN_X", "BTN_Y",
        "BTN_TL", "BTN_TR", "BTN_SELECT", "BTN_START",
        "BTN_MODE", "BTN_THUMBL", "BTN_THUMBR",
    )
    if hasattr(ecodes, n)
}


def _abs_codes(caps):
    """Extract integer codes from EV_ABS capabilities (may be tuples)."""
    return {c if isinstance(c, int) else c[0] for c in caps.get(ecodes.EV_ABS, [])}


def is_gamepad(dev):
    """A gamepad has absolute axes (stick) AND gamepad-specific buttons."""
    caps = dev.capabilities()
    if ecodes.EV_ABS not in caps or ecodes.EV_KEY not in caps:
        return False
    has_stick = bool(_abs_codes(caps) & {ecodes.ABS_X, ecodes.ABS_Y})
    has_btn = bool(set(caps[ecodes.EV_KEY]) & _GAMEPAD_BTNS)
    return has_stick and has_btn


def is_keyboard(dev):
    caps = dev.capabilities()
    keys = set(caps.get(ecodes.EV_KEY, []))
    return bool(keys & {ecodes.KEY_A, ecodes.KEY_ENTER, ecodes.KEY_SPACE})


def is_mouse(dev):
    caps = dev.capabilities()
    rels = {c if isinstance(c, int) else c[0] for c in caps.get(ecodes.EV_REL, [])}
    return bool(rels & {ecodes.REL_X, ecodes.REL_Y})


def discover_devices(known_paths=None, ignored_paths=None):
    """Find keyboards and mice, excluding gamepads and already-known paths."""
    known_paths = known_paths or set()
    ignored_paths = ignored_paths if ignored_paths is not None else set()
    found = {}
    for path in list_devices():
        if path in known_paths or path in ignored_paths:
            continue
        try:
            dev = InputDevice(path)
        except (PermissionError, OSError):
            continue
        if is_gamepad(dev):
            log.info("Skipping gamepad: %s (%s)", dev.name, path)
            dev.close()
            ignored_paths.add(path)
            continue
        kinds = []
        if is_keyboard(dev):
            kinds.append("keyboard")
        if is_mouse(dev):
            kinds.append("mouse")
        if kinds:
            found[path] = dev
            log.info("Found %s: %s (%s)", "+".join(kinds), dev.name, path)
        else:
            dev.close()
            ignored_paths.add(path)
    return found


def main():
    display_name = os.environ.get("DISPLAY", ":1")
    grab = os.environ.get("LOCAL_INPUT_GRAB", "true").lower() != "false"

    log.info("Connecting to X display %s", display_name)

    try:
        dpy = xdisplay.Display(display_name)
    except Exception as e:
        log.error("Cannot connect to display %s: %s", display_name, e)
        sys.exit(1)

    if not dpy.has_extension("XTEST"):
        log.error("XTEST extension not available on %s", display_name)
        sys.exit(1)

    log.info("XTEST available. Discovering input devices...")

    ignored_paths = set()
    devices = discover_devices(ignored_paths=ignored_paths)
    if not devices:
        log.warning("No keyboard/mouse found yet. Will scan for hotplug.")

    if grab:
        for path, dev in devices.items():
            try:
                dev.grab()
                log.info("Grabbed: %s", dev.name)
            except OSError as e:
                log.warning("Cannot grab %s: %s", dev.name, e)

    # Signal handling
    running = True

    def _stop(sig, frame):
        nonlocal running
        running = False

    signal.signal(signal.SIGTERM, _stop)
    signal.signal(signal.SIGINT, _stop)

    last_scan = time.monotonic()
    SCAN_INTERVAL = 5.0

    log.info("Input forwarding active (grab=%s).", grab)

    while running:
        # Build fd -> device map
        fd_map = {}
        for path in list(devices):
            dev = devices[path]
            try:
                fd_map[dev.fd] = (path, dev)
            except Exception:
                devices.pop(path, None)

        if not fd_map:
            time.sleep(1)
        else:
            try:
                readable, _, _ = select.select(list(fd_map), [], [], 1.0)
            except (ValueError, OSError):
                continue

            needs_flush = False

            for fd in readable:
                if fd not in fd_map:
                    continue
                path, dev = fd_map[fd]
                try:
                    for ev in dev.read():
                        if ev.type == ecodes.EV_KEY:
                            if ev.code in BUTTON_MAP:
                                # Mouse button
                                btn = BUTTON_MAP[ev.code]
                                if ev.value == 1:
                                    xtest.fake_input(dpy, X.ButtonPress, btn)
                                elif ev.value == 0:
                                    xtest.fake_input(dpy, X.ButtonRelease, btn)
                                needs_flush = True
                            elif ev.value in (0, 1):
                                # Keyboard key (ignore value=2 repeat;
                                # X server handles auto-repeat from KeyPress)
                                kc = ev.code + EVDEV_X11_OFFSET
                                etype = X.KeyPress if ev.value == 1 else X.KeyRelease
                                xtest.fake_input(dpy, etype, kc)
                                needs_flush = True

                        elif ev.type == ecodes.EV_REL:
                            if ev.code == ecodes.REL_X:
                                xtest.fake_input(
                                    dpy, X.MotionNotify,
                                    detail=True, x=ev.value, y=0,
                                )
                                needs_flush = True
                            elif ev.code == ecodes.REL_Y:
                                xtest.fake_input(
                                    dpy, X.MotionNotify,
                                    detail=True, x=0, y=ev.value,
                                )
                                needs_flush = True
                            elif ev.code == ecodes.REL_WHEEL:
                                btn = 4 if ev.value > 0 else 5
                                for _ in range(abs(ev.value)):
                                    xtest.fake_input(dpy, X.ButtonPress, btn)
                                    xtest.fake_input(dpy, X.ButtonRelease, btn)
                                needs_flush = True

                except (OSError, IOError):
                    log.warning("Device disconnected: %s (%s)", dev.name, path)
                    try:
                        dev.close()
                    except Exception:
                        pass
                    devices.pop(path, None)

            if needs_flush:
                try:
                    dpy.flush()
                except Exception as e:
                    log.error("X display error: %s", e)
                    break

        # Periodic hotplug scan
        now = time.monotonic()
        if now - last_scan >= SCAN_INTERVAL:
            last_scan = now
            new_devs = discover_devices(
                known_paths=set(devices), ignored_paths=ignored_paths,
            )
            for p, d in new_devs.items():
                if grab:
                    try:
                        d.grab()
                        log.info("Grabbed: %s", d.name)
                    except OSError:
                        pass
            devices.update(new_devs)

    # Cleanup
    log.info("Shutting down.")
    for path, dev in devices.items():
        try:
            if grab:
                dev.ungrab()
            dev.close()
        except Exception:
            pass
    try:
        dpy.close()
    except Exception:
        pass


if __name__ == "__main__":
    main()
