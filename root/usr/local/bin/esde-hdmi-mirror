#!/usr/bin/env bash
# esde-hdmi-mirror — Mirror the Selkies virtual X display to physical HDMI.
#
# Captures the Xvfb virtual display and outputs to a physical HDMI display.
# Tries multiple output methods in order:
#   1. GStreamer ximagesrc → kmssink  (DRM/KMS — best quality, RPi4 native)
#   2. ffmpeg x11grab → fbdev        (Linux framebuffer fallback)
#
# Environment:
#   HDMI_MIRROR          Set to 'true' to enable (required)
#   MIRROR_DISPLAY       X display to capture (default: $DISPLAY or :0)
#   MIRROR_FRAMERATE     Target framerate  (default: 30)
#   MIRROR_DRM_DEVICE    DRM card device for kmssink (auto-detect if unset)
#   MIRROR_CONNECTOR_ID  DRM connector ID for kmssink (auto-detect if unset)
#   MIRROR_FB_DEVICE     Framebuffer device for ffmpeg fallback (/dev/fb0)
set -euo pipefail

display="${MIRROR_DISPLAY:-${DISPLAY:-:0}}"
framerate="${MIRROR_FRAMERATE:-30}"
drm_device="${MIRROR_DRM_DEVICE:-}"
connector_id="${MIRROR_CONNECTOR_ID:-}"
fb_device="${MIRROR_FB_DEVICE:-/dev/fb0}"

# ── Diagnostics ─────────────────────────────────────────────────────
echo "[hdmi-mirror] ===== HDMI Mirror Diagnostics ====="
echo "[hdmi-mirror] Architecture: $(uname -m)"
echo "[hdmi-mirror] Kernel: $(uname -r)"
echo "[hdmi-mirror] Tools:"
echo "[hdmi-mirror]   gst-launch-1.0: $(command -v gst-launch-1.0 2>/dev/null || echo 'NOT FOUND')"
echo "[hdmi-mirror]   gst-inspect-1.0: $(command -v gst-inspect-1.0 2>/dev/null || echo 'NOT FOUND')"
echo "[hdmi-mirror]   ffmpeg: $(command -v ffmpeg 2>/dev/null || echo 'NOT FOUND')"
echo "[hdmi-mirror]   xdpyinfo: $(command -v xdpyinfo 2>/dev/null || echo 'NOT FOUND')"

if command -v gst-inspect-1.0 >/dev/null 2>&1; then
  echo "[hdmi-mirror] GStreamer plugins:"
  echo "[hdmi-mirror]   kmssink: $(gst-inspect-1.0 kmssink >/dev/null 2>&1 && echo 'YES' || echo 'NO')"
  echo "[hdmi-mirror]   ximagesrc: $(gst-inspect-1.0 ximagesrc >/dev/null 2>&1 && echo 'YES' || echo 'NO')"
  echo "[hdmi-mirror]   videoconvert: $(gst-inspect-1.0 videoconvert >/dev/null 2>&1 && echo 'YES' || echo 'NO')"
  echo "[hdmi-mirror]   videoscale: $(gst-inspect-1.0 videoscale >/dev/null 2>&1 && echo 'YES' || echo 'NO')"
else
  echo "[hdmi-mirror] GStreamer: NOT INSTALLED"
fi

echo "[hdmi-mirror] DRI devices:"
if [[ -d /dev/dri ]]; then
  ls -la /dev/dri/ 2>/dev/null | while IFS= read -r line; do
    echo "[hdmi-mirror]   ${line}"
  done
else
  echo "[hdmi-mirror]   /dev/dri NOT FOUND"
fi

echo "[hdmi-mirror] Framebuffers: $(ls /dev/fb* 2>/dev/null || echo 'NONE')"

# Enumerate DRM connectors for each card
for card in /dev/dri/card*; do
  [[ -e "${card}" ]] || continue
  card_name="$(basename "${card}")"
  echo "[hdmi-mirror] DRM connectors on ${card_name}:"
  card_sys="/sys/class/drm"
  for connector_dir in "${card_sys}/${card_name}"-*; do
    [[ -d "${connector_dir}" ]] || continue
    conn_name="$(basename "${connector_dir}")"
    conn_status="$(cat "${connector_dir}/status" 2>/dev/null || echo 'unknown')"
    conn_enabled="$(cat "${connector_dir}/enabled" 2>/dev/null || echo 'unknown')"
    echo "[hdmi-mirror]   ${conn_name}: status=${conn_status}, enabled=${conn_enabled}"
  done
done

echo "[hdmi-mirror] ===== End Diagnostics ====="

# ── Auto-detect DRM device for RPi4 / vc4 ──────────────────────────
# On Raspberry Pi 4, there are typically two DRM cards:
#   card0 = vc4 (display controller w/ HDMI connectors)
#   card1 = v3d (3D rendering only, no connectors)
# We need the card that has HDMI connectors.
auto_detect_drm_device() {
  for card in /dev/dri/card*; do
    [[ -e "${card}" ]] || continue
    card_name="$(basename "${card}")"
    # Check if this card has any HDMI connector
    for connector_dir in /sys/class/drm/"${card_name}"-HDMI-*; do
      if [[ -d "${connector_dir}" ]]; then
        echo "${card}"
        return 0
      fi
    done
  done
  # Fallback: return first card
  local first_card
  first_card="$(ls /dev/dri/card* 2>/dev/null | head -1)"
  if [[ -n "${first_card}" ]]; then
    echo "${first_card}"
    return 0
  fi
  return 1
}

# Auto-detect connector ID for a given DRM card
# Returns the connector ID of the first connected HDMI port
auto_detect_connector() {
  local card_dev="$1"
  local card_name
  card_name="$(basename "${card_dev}")"

  # First try: find a connected HDMI connector
  for connector_dir in /sys/class/drm/"${card_name}"-HDMI-*; do
    [[ -d "${connector_dir}" ]] || continue
    local status
    status="$(cat "${connector_dir}/status" 2>/dev/null)" || continue
    if [[ "${status}" == "connected" ]]; then
      # Extract connector ID from the uevent file or connector_id file
      local cid
      if [[ -r "${connector_dir}/connector_id" ]]; then
        cid="$(cat "${connector_dir}/connector_id" 2>/dev/null)"
      fi
      if [[ -n "${cid:-}" ]]; then
        echo "${cid}"
        return 0
      fi
    fi
  done

  # Second try: any HDMI connector regardless of status
  for connector_dir in /sys/class/drm/"${card_name}"-HDMI-*; do
    [[ -d "${connector_dir}" ]] || continue
    local cid
    if [[ -r "${connector_dir}/connector_id" ]]; then
      cid="$(cat "${connector_dir}/connector_id" 2>/dev/null)"
    fi
    if [[ -n "${cid:-}" ]]; then
      echo "${cid}"
      return 0
    fi
  done
  return 1
}

# ── Wait for the virtual X display to become reachable ──────────────
echo "[hdmi-mirror] Waiting for X display ${display}..."
attempts=0
while ! DISPLAY="${display}" xdpyinfo >/dev/null 2>&1; do
  attempts=$((attempts + 1))
  if (( attempts > 60 )); then
    echo "[hdmi-mirror] Error: display ${display} not ready after 60 s." >&2
    echo "[hdmi-mirror] Sleeping to avoid restart loop." >&2
    exec sleep infinity
  fi
  sleep 1
done

# ── Wait for Selkies to resize the display to a sane resolution ─────
# Xvfb can initially report a huge resolution (e.g. 15360x8640) before
# Selkies sets its actual resolution. Wait for something ≤ 4K.
echo "[hdmi-mirror] Waiting for Selkies to set display resolution..."
resolution_ok=false
for _ in $(seq 1 30); do
  geometry="$(DISPLAY="${display}" xdpyinfo | awk '/dimensions:/{print $2}')"
  res_w="${geometry%x*}"
  res_h="${geometry#*x}"
  if (( res_w <= 3840 && res_h <= 2160 )); then
    resolution_ok=true
    break
  fi
  echo "[hdmi-mirror]   Current: ${geometry} (waiting for ≤3840x2160)..."
  sleep 2
done

geometry="$(DISPLAY="${display}" xdpyinfo | awk '/dimensions:/{print $2}')"
if [[ "${resolution_ok}" != "true" ]]; then
  echo "[hdmi-mirror] Resolution still ${geometry} after 60 s — Selkies has not resized yet." >&2
  echo "[hdmi-mirror] Exiting so the service can restart and retry." >&2
  exit 1
fi
echo "[hdmi-mirror] Display ${display} ready (${geometry}). Mirroring at ${framerate} fps."

# ── Method 1: GStreamer ximagesrc → kmssink (DRM/KMS) ───────────────
if command -v gst-launch-1.0 >/dev/null 2>&1 \
   && gst-inspect-1.0 kmssink  >/dev/null 2>&1 \
   && gst-inspect-1.0 ximagesrc >/dev/null 2>&1; then

  # Auto-detect DRM device if not specified
  if [[ -z "${drm_device}" ]]; then
    drm_device="$(auto_detect_drm_device)" || true
  fi

  # Auto-detect connector if not specified
  if [[ -z "${connector_id}" && -n "${drm_device}" ]]; then
    connector_id="$(auto_detect_connector "${drm_device}")" || true
  fi

  echo "[hdmi-mirror] Using GStreamer ximagesrc → kmssink."
  echo "[hdmi-mirror]   DRM device: ${drm_device:-auto}"
  echo "[hdmi-mirror]   Connector ID: ${connector_id:-auto}"

  # Build kmssink property string.
  # Only include connector-id; let kmssink auto-detect the driver/device.
  # Setting driver-name to the sysfs name (e.g. "vc4-drm") does NOT work
  # because drmOpen() expects the DRM version name (e.g. "vc4").
  kms_props=""
  if [[ -n "${connector_id}" ]]; then
    kms_props="connector-id=${connector_id}"
  fi

  # Build a list of driver names to try.
  # Read the real sysfs driver name and derive the DRM version name from it
  # (strip the common "-drm" suffix, e.g. "vc4-drm" → "vc4").
  driver_names=()
  if [[ -n "${drm_device}" ]]; then
    card_name="$(basename "${drm_device}")"
    sysfs_driver="$(cat "/sys/class/drm/${card_name}/device/uevent" 2>/dev/null \
                    | sed -n 's/^DRIVER=//p')" || sysfs_driver=""
    if [[ -n "${sysfs_driver}" ]]; then
      stripped="${sysfs_driver%-drm}"    # "vc4-drm" → "vc4"
      # Add stripped name first (most likely to work with drmOpen)
      [[ "${stripped}" != "${sysfs_driver}" ]] && driver_names+=("${stripped}")
      driver_names+=("${sysfs_driver}")
    fi
  fi
  # Append common RPi driver names as last-resort fallbacks (skip duplicates)
  for fallback in vc4; do
    dup=0
    for existing in "${driver_names[@]+"${driver_names[@]}"}"; do
      [[ "${existing}" == "${fallback}" ]] && dup=1 && break
    done
    (( dup )) || driver_names+=("${fallback}")
  done

  # Attempt 1: auto-detect (no driver-name, let kmssink probe)
  echo "[hdmi-mirror] Attempt: kmssink (auto) ${kms_props}"
  if gst-launch-1.0 -e \
    ximagesrc display-name="${display}" use-damage=0 show-pointer=true ! \
    "video/x-raw,framerate=${framerate}/1" ! \
    videoconvert ! \
    videoscale ! \
    kmssink ${kms_props} 2>&1; then
    echo "[hdmi-mirror] GStreamer pipeline ended. Sleeping." >&2
    exec sleep infinity
  fi
  echo "[hdmi-mirror] Auto-detect failed." >&2

  # Attempt 2+: try detected / well-known driver names
  for try_driver in "${driver_names[@]+"${driver_names[@]}"}"; do
    echo "[hdmi-mirror] Attempt: kmssink driver-name=${try_driver} ${kms_props}"
    if gst-launch-1.0 -e \
      ximagesrc display-name="${display}" use-damage=0 show-pointer=true ! \
      "video/x-raw,framerate=${framerate}/1" ! \
      videoconvert ! \
      videoscale ! \
      kmssink driver-name="${try_driver}" ${kms_props} 2>&1; then
      echo "[hdmi-mirror] GStreamer pipeline ended. Sleeping." >&2
      exec sleep infinity
    fi
    echo "[hdmi-mirror] driver-name=${try_driver} failed." >&2
  done

  echo "[hdmi-mirror] All GStreamer kmssink attempts failed. Trying fallback..." >&2
fi

# ── Method 2: ffmpeg → Linux framebuffer (/dev/fb0) ─────────────────
if command -v ffmpeg >/dev/null 2>&1 && [[ -e "${fb_device}" ]]; then
  width="${geometry%x*}"
  height="${geometry#*x}"

  # Detect the framebuffer's native pixel format and resolution
  fb_name="$(basename "${fb_device}")"
  fb_bits="$(cat /sys/class/graphics/"${fb_name}"/bits_per_pixel 2>/dev/null)" || fb_bits=""
  fb_res="$(cat /sys/class/graphics/"${fb_name}"/virtual_size 2>/dev/null)" || fb_res=""
  echo "[hdmi-mirror] Framebuffer: ${fb_device}, bits_per_pixel=${fb_bits:-?}, virtual_size=${fb_res:-?}"

  # Build list of pixel formats to try.
  # The fbdev muxer in ffmpeg only supports a limited set of formats and the
  # sysfs bits_per_pixel value sometimes does not match what ffmpeg accepts.
  # We try the most likely format first based on bpp, then fall back to
  # rgb565le (the universal RPi default) and other candidates.
  pix_fmts=()
  case "${fb_bits}" in
    16) pix_fmts+=("rgb565le") ;;
    24) pix_fmts+=("bgr24") ;;
    32) pix_fmts+=("bgra") ;;
  esac
  # Always include rgb565le as the safest fallback (skip if already first)
  [[ "${pix_fmts[0]:-}" != "rgb565le" ]] && pix_fmts+=("rgb565le")

  # Scale to match framebuffer resolution if available
  scale_filter=""
  if [[ -n "${fb_res}" ]]; then
    fb_w="${fb_res%%,*}"
    fb_h="${fb_res##*,}"
    if [[ -n "${fb_w}" && -n "${fb_h}" && "${fb_w}" -gt 0 && "${fb_h}" -gt 0 ]]; then
      scale_filter="scale=${fb_w}:${fb_h},"
    fi
  fi

  for pix_fmt in "${pix_fmts[@]}"; do
    echo "[hdmi-mirror] Trying ffmpeg → ${fb_device} (source=${width}x${height}, pix_fmt=${pix_fmt})."
    ffmpeg -loglevel warning \
      -probesize 50M \
      -f x11grab -video_size "${width}x${height}" -framerate "${framerate}" \
      -i "${display}" \
      -vf "${scale_filter}format=${pix_fmt}" -f fbdev "${fb_device}" 2>&1 && \
      { echo "[hdmi-mirror] ffmpeg pipeline ended. Sleeping." >&2; exec sleep infinity; }
    echo "[hdmi-mirror] pix_fmt=${pix_fmt} failed." >&2
  done
  echo "[hdmi-mirror] All ffmpeg attempts failed." >&2
fi

echo "============================================================" >&2
echo "[hdmi-mirror] ERROR: no output method available." >&2
echo "" >&2
echo "  Checked for:" >&2
echo "    1. gst-launch-1.0 + kmssink + ximagesrc" >&2
echo "       gst-launch-1.0: $(command -v gst-launch-1.0 2>/dev/null || echo 'MISSING')" >&2
if command -v gst-inspect-1.0 >/dev/null 2>&1; then
  echo "       kmssink: $(gst-inspect-1.0 kmssink >/dev/null 2>&1 && echo 'OK' || echo 'MISSING')" >&2
  echo "       ximagesrc: $(gst-inspect-1.0 ximagesrc >/dev/null 2>&1 && echo 'OK' || echo 'MISSING')" >&2
fi
echo "    2. ffmpeg + ${fb_device}" >&2
echo "       ffmpeg: $(command -v ffmpeg 2>/dev/null || echo 'MISSING')" >&2
echo "       ${fb_device}: $([[ -e "${fb_device}" ]] && echo 'EXISTS' || echo 'MISSING')" >&2
echo "" >&2
echo "  To fix: rebuild the image with --no-cache" >&2
echo "    docker compose --profile selkies build --no-cache" >&2
echo "============================================================" >&2
echo "[hdmi-mirror] Sleeping to avoid restart loop." >&2
exec sleep infinity
