#!/usr/bin/env bash
# esde-provision — Sidecar entrypoint that provisions an emulator's binary,
# runtime libraries, and (for RetroArch) libretro cores to a shared volume.
#
# ES-DE's container mounts the volume at /opt/emulators and calls the
# emulator via esde-emuwrap, which resolves the emulator name from its
# symlink, sets LD_LIBRARY_PATH, then exec's the real binary.
#
# Environment variables:
#   EMULATOR_NAME    — emulator binary name (default: retroarch)
#   EMULATOR_BINARY  — path to installed binary (default: /usr/bin/${EMULATOR_NAME})
#
# This script runs once and exits (init-container pattern).
set -euo pipefail

EMULATOR_NAME="${EMULATOR_NAME:-retroarch}"
EMULATOR_BINARY="${EMULATOR_BINARY:-/usr/bin/${EMULATOR_NAME}}"
TAG="[esde-provision:${EMULATOR_NAME}]"
EXPORT_DIR="/export/${EMULATOR_NAME}"

echo "${TAG} Provisioning ${EMULATOR_NAME} to ${EXPORT_DIR}..."

# --- Create directory structure ---
mkdir -p "${EXPORT_DIR}/bin" "${EXPORT_DIR}/lib"

# --- Copy emulator binary ---
if [[ ! -x "${EMULATOR_BINARY}" ]]; then
  echo "${TAG} Error: ${EMULATOR_BINARY} not found in provider image." >&2
  exit 1
fi
cp -a "${EMULATOR_BINARY}" "${EXPORT_DIR}/bin/${EMULATOR_NAME}"

# --- Copy libretro cores (RetroArch-specific) ---
if [[ "${EMULATOR_NAME}" == "retroarch" ]]; then
  mkdir -p "${EXPORT_DIR}/cores"
  core_count=0
  for dir in /usr/lib/libretro /usr/lib/*/libretro; do
    [[ -d "${dir}" ]] || continue
    for core in "${dir}"/*.so; do
      [[ -f "${core}" ]] || continue
      cp -a "${core}" "${EXPORT_DIR}/cores/"
      core_count=$((core_count + 1))
    done
  done
  echo "${TAG} Copied ${core_count} libretro core(s)."
fi

# --- Copy shared libraries that the emulator needs ---
# Only copy libs that are NOT in the base Ubuntu install (libc, libm, libdl, etc.
# are guaranteed to exist in the ES-DE container since it uses the same Ubuntu base).
# This avoids overriding system libs while ensuring emulator-specific deps are present.
_copy_deps() {
  local binary="$1"
  ldd "${binary}" 2>/dev/null | while read -r line; do
    # Parse lines like: libfoo.so.1 => /usr/lib/x86_64-linux-gnu/libfoo.so.1 (0x...)
    lib_path="$(echo "${line}" | grep -oP '/\S+\.so[.\d]*' | head -1)" || true
    [[ -z "${lib_path}" ]] && continue
    [[ -f "${lib_path}" ]] || continue
    lib_name="$(basename "${lib_path}")"
    # Skip core system libs (always present in any Ubuntu container)
    case "${lib_name}" in
      libc.so*|libm.so*|libdl.so*|librt.so*|libpthread.so*|ld-linux*|libgcc_s.so*|libstdc++.so*)
        continue ;;
    esac
    if [[ ! -f "${EXPORT_DIR}/lib/${lib_name}" ]]; then
      cp -a "${lib_path}" "${EXPORT_DIR}/lib/"
    fi
  done
}

echo "${TAG} Copying shared library dependencies..."
_copy_deps "${EXPORT_DIR}/bin/${EMULATOR_NAME}"
if [[ -d "${EXPORT_DIR}/cores" ]]; then
  for core in "${EXPORT_DIR}/cores"/*.so; do
    [[ -f "${core}" ]] || continue
    _copy_deps "${core}"
  done
fi

lib_count="$(find "${EXPORT_DIR}/lib" -name '*.so*' | wc -l)"
echo "${TAG} Copied ${lib_count} shared libraries."

# --- Write version stamp ---
emu_ver="$("${EXPORT_DIR}/bin/${EMULATOR_NAME}" --version 2>&1 | head -1)" || emu_ver="unknown"
echo "${emu_ver}" > "${EXPORT_DIR}/VERSION"
echo "${TAG} Provisioned: ${emu_ver}"

# --- RetroArch-specific: write default config ---
if [[ "${EMULATOR_NAME}" == "retroarch" && ! -f "${EXPORT_DIR}/retroarch.cfg" ]]; then
  printf '%s\n' \
    '# Auto-generated by esde-provision sidecar.' \
    '# ES-DE overrides most settings via command-line flags.' \
    '# This file sets the core search path for the sidecar volume layout.' \
    'libretro_directory = "/opt/emulators/retroarch/cores"' \
    > "${EXPORT_DIR}/retroarch.cfg"
  echo "${TAG} Created default retroarch.cfg."
fi

total_size="$(du -sh "${EXPORT_DIR}" | cut -f1)"
echo "${TAG} Done. Total size: ${total_size}"
