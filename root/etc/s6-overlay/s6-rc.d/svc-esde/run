#!/usr/bin/with-contenv bash
set -euo pipefail

display_num="${DISPLAY_NUM:-0}"
export DISPLAY="${DISPLAY:-:${display_num}}"

if [[ -z ${XDG_RUNTIME_DIR:-} ]]; then
  echo "[svc-esde] Warning: XDG_RUNTIME_DIR not set. Setting to /run/esde" >&2
  export XDG_RUNTIME_DIR=/run/esde
fi

mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${XDG_RUNTIME_DIR}"

# --- Device group membership ---
# The abc user needs supplementary groups for GPU, audio, and input access.
# s6-setuidgid reads supplementary groups from /etc/group, so the user must
# be a member before we drop privileges.
app_user="${APP_USER:-abc}"
for grp in video render audio input; do
  if getent group "${grp}" >/dev/null 2>&1; then
    if ! id -nG "${app_user}" 2>/dev/null | grep -qw "${grp}"; then
      usermod -aG "${grp}" "${app_user}" 2>/dev/null || true
    fi
  fi
done

# Match host device GIDs for /dev/dri and /dev/snd if they differ from standard groups
if [[ -e /dev/dri/card0 ]]; then
  dri_gid="$(stat -c '%g' /dev/dri/card0 2>/dev/null)" || true
  if [[ -n "${dri_gid}" && "${dri_gid}" != "0" ]]; then
    if ! id -G "${app_user}" 2>/dev/null | grep -qw "${dri_gid}"; then
      # Create/reuse a group matching the host GID and add the user
      dri_grp="$(getent group "${dri_gid}" 2>/dev/null | cut -d: -f1)" || true
      if [[ -z "${dri_grp}" ]]; then
        groupadd -g "${dri_gid}" hostdri 2>/dev/null || true
        dri_grp="hostdri"
      fi
      usermod -aG "${dri_grp}" "${app_user}" 2>/dev/null || true
      echo "[svc-esde] Added ${app_user} to group ${dri_grp} (GID ${dri_gid}) for /dev/dri access."
    fi
  fi
fi

if [[ -e /dev/snd/controlC0 ]]; then
  snd_gid="$(stat -c '%g' /dev/snd/controlC0 2>/dev/null)" || true
  if [[ -n "${snd_gid}" && "${snd_gid}" != "0" ]]; then
    if ! id -G "${app_user}" 2>/dev/null | grep -qw "${snd_gid}"; then
      snd_grp="$(getent group "${snd_gid}" 2>/dev/null | cut -d: -f1)" || true
      if [[ -z "${snd_grp}" ]]; then
        groupadd -g "${snd_gid}" hostaudio 2>/dev/null || true
        snd_grp="hostaudio"
      fi
      usermod -aG "${snd_grp}" "${app_user}" 2>/dev/null || true
      echo "[svc-esde] Added ${app_user} to group ${snd_grp} (GID ${snd_gid}) for /dev/snd access."
    fi
  fi
fi

# Match host device GIDs for /dev/input (gamepads, keyboards, mice)
if [[ -d /dev/input ]]; then
  for _input_dev in /dev/input/event*; do
    [[ -e "${_input_dev}" ]] || continue
    input_gid="$(stat -c '%g' "${_input_dev}" 2>/dev/null)" || true
    if [[ -n "${input_gid}" && "${input_gid}" != "0" ]]; then
      if ! id -G "${app_user}" 2>/dev/null | grep -qw "${input_gid}"; then
        input_grp="$(getent group "${input_gid}" 2>/dev/null | cut -d: -f1)" || true
        if [[ -z "${input_grp}" ]]; then
          groupadd -g "${input_gid}" hostinput 2>/dev/null || true
          input_grp="hostinput"
        fi
        usermod -aG "${input_grp}" "${app_user}" 2>/dev/null || true
        echo "[svc-esde] Added ${app_user} to group ${input_grp} (GID ${input_gid}) for /dev/input access."
      fi
    fi
    break  # Only need to check one device for the GID
  done
fi

# --- Audio detection and setup ---
# ES-DE requires PulseAudio or PipeWire; raw ALSA is not supported.

# Load the USB audio kernel module if available. Without it, USB sound cards
# will not appear in /proc/asound/cards even when /dev/bus/usb is passed through.
if [[ -d /dev/bus/usb ]]; then
  if modprobe snd-usb-audio 2>/dev/null; then
    echo "[svc-esde] Loaded snd-usb-audio kernel module."
  else
    echo "[svc-esde] Note: Could not load snd-usb-audio module (may already be loaded, or host kernel lacks it)." >&2
  fi
fi

# Start udevd early so PulseAudio's module-udev-detect can discover ALSA cards,
# and Xorg can later discover input devices.
if ! pidof systemd-udevd >/dev/null 2>&1 && ! pidof udevd >/dev/null 2>&1; then
  if [[ -x /usr/lib/systemd/systemd-udevd ]]; then
    echo "[svc-esde] Starting udevd for device discovery."
    /usr/lib/systemd/systemd-udevd --daemon 2>/dev/null || true
    udevadm trigger --action=add 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
    # Retrigger USB sound and input subsystems — USB devices may need extra time
    udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=input 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
  elif command -v udevd >/dev/null 2>&1; then
    echo "[svc-esde] Starting udevd for device discovery."
    udevd --daemon 2>/dev/null || true
    udevadm trigger --action=add 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=input 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
  else
    echo "[svc-esde] Warning: udevd not found. Audio detection and input hotplug may not work." >&2
  fi
fi

# 1. Detect ALSA hardware (sound cards visible to the kernel)
if [[ -d /dev/snd ]]; then
  snd_devices="$(ls /dev/snd/ 2>/dev/null)" || true
  if [[ -n "${snd_devices}" ]]; then
    echo "[svc-esde] Audio hardware detected in /dev/snd: $(echo "${snd_devices}" | tr '\n' ' ')"
  else
    echo "[svc-esde] Warning: /dev/snd exists but contains no device nodes." >&2
  fi
  if [[ -r /proc/asound/cards ]]; then
    while IFS= read -r line; do
      echo "[svc-esde]   ALSA card: ${line}"
    done < /proc/asound/cards
  fi
else
  echo "[svc-esde] Warning: /dev/snd not found. No sound devices available." >&2
  echo "[svc-esde]   For USB audio: pass --device /dev/snd:/dev/snd or use privileged mode." >&2
  echo "[svc-esde]   Ensure the host kernel has the snd-usb-audio module loaded (modprobe snd-usb-audio)." >&2
fi

# Check if USB audio devices are expected but missing.
# After modprobe + udev settle, USB audio cards may take several seconds to
# fully enumerate (chipset initialization, firmware load, etc.).
# Wait up to 15 seconds, retriggering udev periodically.
if [[ -d /dev/bus/usb ]]; then
  _usb_audio_found=false
  for _usb_wait in $(seq 1 15); do
    # Method 1: check /proc/asound/cards for USB-named cards
    if grep -qi 'usb' /proc/asound/cards 2>/dev/null; then
      _usb_audio_found=true; break
    fi
    # Method 2: check sysfs for cards on the USB subsystem
    # (catches devices whose ALSA name does not contain "USB")
    for _scard in /sys/class/sound/card*/device; do
      [[ -L "${_scard}" ]] || continue
      if [[ "$(basename "$(readlink -f "${_scard}/subsystem" 2>/dev/null)" 2>/dev/null)" == "usb" ]]; then
        _usb_audio_found=true; break 2
      fi
    done
    # Retrigger sound subsystem every 5s in case the device appeared late
    if (( _usb_wait % 5 == 0 )); then
      udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
      udevadm settle --timeout=3 2>/dev/null || true
    fi
    sleep 1
  done

  if ${_usb_audio_found}; then
    echo "[svc-esde] USB audio card(s) detected in ALSA."
  else
    echo "[svc-esde] Note: /dev/bus/usb is available but no USB audio cards found in ALSA after 15s."
    echo "[svc-esde]   If you have a USB audio device:"
    echo "[svc-esde]     1. On the HOST, run: sudo modprobe snd-usb-audio"
    echo "[svc-esde]     2. On the HOST, verify: cat /proc/asound/cards  (should list your device)"
    echo "[svc-esde]     3. Ensure the device is plugged in and powered"
    echo "[svc-esde]     4. Restart the container after steps 1-3"
    # Show visible USB devices for diagnostics
    if [[ -d /sys/bus/usb/devices ]]; then
      echo "[svc-esde]   USB devices visible to the container:"
      for _uprod in /sys/bus/usb/devices/*/product; do
        [[ -r "${_uprod}" ]] || continue
        _mfr="$(cat "$(dirname "${_uprod}")/manufacturer" 2>/dev/null)" || true
        _prd="$(cat "${_uprod}" 2>/dev/null)" || true
        [[ -n "${_prd}" ]] && echo "[svc-esde]     ${_mfr:+${_mfr} }${_prd}"
      done
    fi
  fi
fi

# 2. Start PulseAudio
if command -v pulseaudio >/dev/null 2>&1; then
  if ! s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    s6-setuidgid "${APP_USER:-abc}" pulseaudio --start --exit-idle-time=-1 --daemonize=yes 2>/dev/null || \
      echo "[svc-esde] Warning: PulseAudio failed to start. Audio may be unavailable." >&2
  fi

  # 3. Configure default sink (wait for PulseAudio to discover devices)
  # USB audio devices can take several seconds to be discovered by
  # module-udev-detect.  Wait up to 20s for a hardware ALSA sink.
  if s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    echo "[svc-esde] Waiting for PulseAudio to discover audio devices..."
    _hw_sink=""
    for _wait in $(seq 1 20); do
      sink_list="$(s6-setuidgid "${APP_USER:-abc}" pactl list short sinks 2>/dev/null)" || true
      # Priority: 1) USB audio  2) 3.5mm analog  3) any ALSA (usually HDMI)
      _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*usb' | head -1 | awk '{print $2}')" || true
      if [[ -z "${_hw_sink}" ]]; then
        # 3.5mm analog on RPi appears as bcm2835*.analog or platform-*.analog
        _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*analog' | head -1 | awk '{print $2}')" || true
      fi
      if [[ -z "${_hw_sink}" ]]; then
        _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output' | head -1 | awk '{print $2}')" || true
      fi
      if [[ -n "${_hw_sink}" ]]; then
        break
      fi
      sleep 1
    done

    # Log all discovered sinks for troubleshooting
    sink_list="$(s6-setuidgid "${APP_USER:-abc}" pactl list short sinks 2>/dev/null)" || true
    if [[ -n "${sink_list}" ]]; then
      echo "[svc-esde] PulseAudio sinks available:"
      while IFS= read -r sink_line; do
        echo "[svc-esde]   ${sink_line}"
      done <<< "${sink_list}"
    else
      echo "[svc-esde] Warning: PulseAudio running but no sinks detected." >&2
    fi

    # Set explicit sink if LOCAL_AUDIO_SINK is defined, otherwise prefer hardware ALSA sink
    if [[ -n "${LOCAL_AUDIO_SINK:-}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${LOCAL_AUDIO_SINK}" 2>/dev/null && \
        echo "[svc-esde] PulseAudio default sink set to: ${LOCAL_AUDIO_SINK}" || \
        echo "[svc-esde] Warning: Could not set LOCAL_AUDIO_SINK=${LOCAL_AUDIO_SINK}. Check sink names above." >&2
    elif [[ -n "${_hw_sink}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${_hw_sink}" 2>/dev/null || true
      echo "[svc-esde] PulseAudio default sink set to hardware device: ${_hw_sink}"
    elif [[ -n "${sink_list}" ]]; then
      default_sink="$(echo "${sink_list}" | head -1 | awk '{print $2}')" || true
      if [[ -n "${default_sink:-}" ]]; then
        s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${default_sink}" 2>/dev/null || true
        echo "[svc-esde] PulseAudio auto-selected sink: ${default_sink}"
      fi
    fi
  fi
else
  echo "[svc-esde] Warning: PulseAudio not installed. Audio will not work." >&2
fi

if [[ ! -e /dev/dri/renderD128 && ! -e /dev/dri/card0 ]]; then
  echo "[svc-esde] Warning: No /dev/dri render/card node detected. Hardware GL may be unavailable." >&2
fi

# --- Gamepad / input device diagnostics ---
if [[ -d /dev/input ]]; then
  _js_devs="$(ls /dev/input/js* 2>/dev/null)" || true
  _ev_devs="$(ls /dev/input/event* 2>/dev/null)" || true
  _js_count="$(echo "${_js_devs}" | grep -c . 2>/dev/null)" || _js_count=0
  _ev_count="$(echo "${_ev_devs}" | grep -c . 2>/dev/null)" || _ev_count=0
  [[ -z "${_js_devs}" ]] && _js_count=0
  [[ -z "${_ev_devs}" ]] && _ev_count=0
  echo "[svc-esde] Input devices: ${_ev_count} event nodes, ${_js_count} joystick nodes."
  for _js in /dev/input/js*; do
    [[ -e "${_js}" ]] || continue
    _js_base="$(basename "${_js}")"
    _js_name="$(cat "/sys/class/input/${_js_base}/device/name" 2>/dev/null)" || true
    if [[ -n "${_js_name}" ]]; then
      echo "[svc-esde]   Gamepad: ${_js_name} (${_js})"
    fi
  done
  # Verify the app user can read at least one event device (required by SDL2)
  _input_access_ok=false
  for _ev in /dev/input/event*; do
    [[ -e "${_ev}" ]] || continue
    if s6-setuidgid "${APP_USER:-abc}" test -r "${_ev}" 2>/dev/null; then
      _input_access_ok=true
    else
      echo "[svc-esde] Warning: ${APP_USER:-abc} cannot read ${_ev} (GID=$(stat -c '%g' "${_ev}" 2>/dev/null))." >&2
      echo "[svc-esde]   Gamepads may not work. Check /dev/input permissions or run privileged." >&2
    fi
    break
  done
  if ${_input_access_ok}; then
    echo "[svc-esde] Input device permissions OK for ${APP_USER:-abc}."
  fi

  # SDL2 GameController mapping diagnostics.
  # ES-DE uses the SDL2 GameController API, which only recognises joysticks that
  # have a mapping in SDL2's built-in gamecontrollerdb.  Generic / no-name USB
  # joysticks (e.g. DragonRise) are often missing and will be invisible to ES-DE
  # even though they appear under /dev/input.
  if [[ ${_js_count} -gt 0 ]]; then
    echo "[svc-esde] Note: ES-DE uses the SDL2 GameController API."
    echo "[svc-esde]   Only controllers with an SDL2 mapping will be usable."
    echo "[svc-esde]   If a gamepad listed above is not detected by ES-DE, add a"
    echo "[svc-esde]   custom mapping via the SDL_GAMECONTROLLERCONFIG env variable."
    echo "[svc-esde]   Generate mappings: https://github.com/gabomdq/SDL_GameControllerDB"
  fi
  echo "[svc-esde] Note: ES-DE does not log individual button/key press events."
  echo "[svc-esde]   To debug input, run inside the container: evtest /dev/input/eventN"
else
  echo "[svc-esde] Warning: /dev/input not found. Gamepads and keyboards will not work." >&2
  echo "[svc-esde]   Pass --device /dev/input:/dev/input or use privileged mode." >&2
fi

# --- Emulator backend detection ---
# ES-DE is a frontend only; it shells out to emulators (usually RetroArch).
# Without an emulator, game launch will fail with:
#   Error: %EMULATOR_RETROARCH% ... not found
#
# Supported RetroArch: https://docs.linuxserver.io/images/docker-retroarch/
#
# Emulators can be provided in three ways:
#   1. Sidecar volume at /opt/emulators/<name> (esde-emulator-provider) — recommended
#   2. INSTALL_RETROARCH=true build arg (baked into image)
#   3. Runtime apt install (not persistent)

_emulators_home="/opt/emulators"
_esde_emuwrap="/usr/local/bin/esde-emuwrap"

# Scan for sidecar-provisioned emulators and set up PATH integration
if [[ -d "${_emulators_home}" ]]; then
  _found_any=false
  for _emu_dir in "${_emulators_home}"/*/; do
    [[ -d "${_emu_dir}" ]] || continue
    _emu_name="$(basename "${_emu_dir}")"
    _emu_bin="${_emu_dir}bin/${_emu_name}"
    if [[ -x "${_emu_bin}" ]] && ! command -v "${_emu_name}" >/dev/null 2>&1; then
      # Symlink generic wrapper as the emulator name on PATH
      if [[ -x "${_esde_emuwrap}" ]]; then
        ln -sf "${_esde_emuwrap}" "/usr/local/bin/${_emu_name}"
        echo "[svc-esde] Sidecar ${_emu_name} detected; linked via esde-emuwrap as /usr/local/bin/${_emu_name}"
      else
        ln -sf "${_emu_bin}" "/usr/local/bin/${_emu_name}"
        echo "[svc-esde] Sidecar ${_emu_name} detected; linked binary to /usr/local/bin/${_emu_name}"
      fi
      if [[ -f "${_emu_dir}VERSION" ]]; then
        echo "[svc-esde]   Version: $(cat "${_emu_dir}VERSION")"
      fi
      _found_any=true
    fi
  done

  # Handle empty volume (sidecar hasn't run)
  if ! ${_found_any} && [[ "$(find "${_emulators_home}" -maxdepth 0 -empty 2>/dev/null)" ]]; then
    echo "[svc-esde] Note: /opt/emulators volume is mounted but empty." >&2
    echo "[svc-esde]   The esde-emulator-provider sidecar may not have run yet." >&2
    echo "[svc-esde]   Start it: docker compose --profile sidecar up esde-emulator-provider" >&2
  fi
fi

# RetroArch-specific: link cores directory into standard search path
_ra_sidecar="${_emulators_home}/retroarch"
if [[ -d "${_ra_sidecar}/cores" ]]; then
  ln -sfn "${_ra_sidecar}/cores" /usr/lib/libretro 2>/dev/null || true
fi

# Check RetroArch status (primary emulator for ES-DE)
if command -v retroarch >/dev/null 2>&1; then
  _ra_source="installed"
  if [[ -x "${_ra_sidecar}/bin/retroarch" ]]; then
    _ra_source="sidecar"
  fi
  _ra_ver="$(retroarch --version 2>&1 | head -1)" || _ra_ver="unknown"
  echo "[svc-esde] RetroArch found (${_ra_source}): ${_ra_ver}"
  # Check for libretro cores
  _core_dirs=(/usr/lib/libretro /usr/lib/*/libretro "${_ra_sidecar}/cores" "${ESDE_HOME:-/config}/.config/retroarch/cores")
  _core_count=0
  for _cdir in "${_core_dirs[@]}"; do
    if [[ -d "${_cdir}" ]]; then
      _n="$(find "${_cdir}" -maxdepth 1 -name '*.so' 2>/dev/null | wc -l)"
      _core_count=$((_core_count + _n))
    fi
  done
  if [[ ${_core_count} -gt 0 ]]; then
    echo "[svc-esde] Found ${_core_count} libretro core(s)."
    # List available cores for diagnostics
    for _cdir in "${_core_dirs[@]}"; do
      [[ -d "${_cdir}" ]] || continue
      for _core_file in "${_cdir}"/*.so; do
        [[ -f "${_core_file}" ]] || continue
        echo "[svc-esde]   Core: $(basename "${_core_file}")"
      done
    done
  else
    echo "[svc-esde] Warning: RetroArch is installed but no libretro cores found." >&2
    echo "[svc-esde]   Games will fail to launch. Install cores via:" >&2
    echo "[svc-esde]     apt install libretro-gambatte libretro-mgba libretro-snes9x ..." >&2
    echo "[svc-esde]   Or use RetroArch: Main Menu > Online Updater > Core Downloader" >&2
  fi
else
  echo "[svc-esde] ================================================" >&2
  echo "[svc-esde] WARNING: RetroArch is NOT installed." >&2
  echo "[svc-esde]   ES-DE is a frontend only — it needs RetroArch" >&2
  echo "[svc-esde]   (or another emulator) to actually run games." >&2
  echo "[svc-esde]   Game launches will fail with:" >&2
  echo "[svc-esde]     Error: %EMULATOR_RETROARCH% ... not found" >&2
  echo "[svc-esde] " >&2
  echo "[svc-esde]   Option 1 — Use the emulator sidecar (recommended):" >&2
  echo "[svc-esde]     docker compose --profile sidecar --profile default up -d" >&2
  echo "[svc-esde]     See: https://docs.linuxserver.io/images/docker-retroarch/" >&2
  echo "[svc-esde] " >&2
  echo "[svc-esde]   Option 2 — Build with RetroArch included:" >&2
  echo "[svc-esde]     docker compose build --build-arg INSTALL_RETROARCH=true" >&2
  echo "[svc-esde] " >&2
  echo "[svc-esde]   Option 3 — Install at runtime (not persistent):" >&2
  echo "[svc-esde]     docker exec -it emulationstation bash" >&2
  echo "[svc-esde]     apt update && apt install -y retroarch libretro-gambatte" >&2
  echo "[svc-esde] " >&2
  echo "[svc-esde]   NOTE: linuxserver/docker-retroarch is a standalone" >&2
  echo "[svc-esde]   streaming app — it CANNOT be used as a backend for" >&2
  echo "[svc-esde]   ES-DE. RetroArch must be in THIS container's" >&2
  echo "[svc-esde]   filesystem (via sidecar volume or direct install)." >&2
  echo "[svc-esde] ================================================" >&2
fi

esde_home="${ESDE_HOME:-/config}"
read -r -a extra_args <<< "${ESDE_ARGS:-}"

# Ensure the ES-DE home directory is writable by the application user
# so ES-DE can create subdirectories such as ROMs, gamelists, etc.
if [[ -d "${esde_home}" ]]; then
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}" 2>/dev/null || true
fi

# --- Symlink external volume mounts into ES-DE's expected paths ---
# docker-compose mounts /roms and /bios as named volumes, but ES-DE expects
# ROMs under ${ESDE_HOME}/ROMs and BIOS files in emulator-specific paths.
# Create symlinks so both locations work seamlessly.
if [[ -d /roms && ! -e "${esde_home}/ROMs" ]]; then
  ln -s /roms "${esde_home}/ROMs"
  chown -h "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/ROMs"
  echo "[svc-esde] Linked /roms -> ${esde_home}/ROMs"
fi
if [[ -d /bios && ! -e "${esde_home}/.emulationstation/bios" ]]; then
  mkdir -p "${esde_home}/.emulationstation"
  ln -s /bios "${esde_home}/.emulationstation/bios"
  chown -h "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/.emulationstation" "${esde_home}/.emulationstation/bios"
  echo "[svc-esde] Linked /bios -> ${esde_home}/.emulationstation/bios"
fi

# --- Seed bundled demo ROMs on first boot ---
# /defaults/roms/ ships with the image and contains freely-licensed homebrew.
# Seed into ES-DE's actual ROM directory so ROMs are found regardless of
# whether /roms is mounted or /config/ROMs is a symlink vs real directory.
_esde_roms="${esde_home}/ROMs"
if [[ -d /defaults/roms ]]; then
  mkdir -p "${_esde_roms}"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_roms}" 2>/dev/null || true
  _rom_file_count="$(find "${_esde_roms}" -mindepth 1 -maxdepth 2 -type f \( -name '*.gb' -o -name '*.gbc' -o -name '*.nes' -o -name '*.sfc' -o -name '*.smc' -o -name '*.bin' -o -name '*.zip' -o -name '*.7z' \) 2>/dev/null | wc -l)"
  if [[ "${_rom_file_count}" -eq 0 ]]; then
    echo "[svc-esde] No ROM files found in ${_esde_roms}; seeding bundled demo ROMs..."
    cp -rn /defaults/roms/* "${_esde_roms}/" 2>/dev/null || true
    chown -R "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_roms}/" 2>/dev/null || true
    echo "[svc-esde] Bundled demo ROMs copied to ${_esde_roms}. Add your own ROMs to replace them."
  fi
fi

# --- Pre-create ROM directory structure ---
# ES-DE shows a first-run "create directories?" wizard when the ROMs directory
# has no system subdirectories. After the user clicks "create", ES-DE loops back
# to the same wizard because there are still 0 games. Pre-creating the structure
# avoids this; ES-DE will instead show the normal empty-gamelist screen.
_roms_dir="${esde_home}/ROMs"
if [[ -d "${_roms_dir}" ]]; then
  _subdir_count="$(find "${_roms_dir}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)"
  if [[ "${_subdir_count}" -eq 0 ]]; then
    echo "[svc-esde] ROM directory is empty; pre-creating system directories..."
    if s6-setuidgid "${APP_USER:-abc}" /usr/local/bin/es-de --create-system-dirs --home "${esde_home}" >/dev/null 2>&1; then
      echo "[svc-esde] System directories created successfully."
    else
      echo "[svc-esde] Warning: --create-system-dirs failed; ES-DE will prompt on first launch." >&2
    fi
  fi
fi

# --- Log forwarding to stdout (for balena / docker logs) ---
# ES-DE and Xorg write to files, not stdout. Tail them in the background
# so their output appears in `balena logs` / `docker logs`.
_log_pids=()
start_log_tailers() {
  local xorg_log="/var/log/Xorg.${display_num}.log"

  # Ensure the ES-DE log directory exists so tail -F can watch for creation
  mkdir -p "${esde_home}/logs"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/logs"

  # ES-DE may write its log to different paths depending on version and config.
  # Search known locations; fall back to the standard path for tail -F to watch.
  local esde_log=""
  local -a esde_log_candidates=(
    "${esde_home}/logs/es_log.txt"
    "${esde_home}/.emulationstation-de/es_log.txt"
    "${esde_home}/ES-DE/logs/es_log.txt"
    "${esde_home}/es_log.txt"
  )
  for _candidate in "${esde_log_candidates[@]}"; do
    if [[ -f "${_candidate}" ]]; then
      esde_log="${_candidate}"
      break
    fi
  done
  # If no existing log file found, watch the standard path for creation
  esde_log="${esde_log:-${esde_log_candidates[0]}}"
  echo "[svc-esde] Tailing ES-DE log: ${esde_log}"

  # Use -n 0 to skip existing content and only show new lines from this session
  tail -n 0 -F "${esde_log}" 2>/dev/null | sed --unbuffered 's/^/[es-de] /' &
  _log_pids+=("$!")
  tail -n 0 -F "${xorg_log}" 2>/dev/null | sed --unbuffered 's/^/[Xorg] /' &
  _log_pids+=("$!")
}

cleanup_log_tailers() {
  for pid in "${_log_pids[@]}"; do
    kill "${pid}" 2>/dev/null || true
  done
  # Also kill any tail children spawned in the pipelines
  jobs -p 2>/dev/null | xargs -r kill 2>/dev/null || true
}
trap cleanup_log_tailers EXIT

echo "[svc-esde] Starting ES-DE with DISPLAY=${DISPLAY}, XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}, and home=${esde_home}"
echo "[svc-esde] Launch target is local device graphics output; no web console or HTTP port is exposed by this image."

# --- udev setup for input device discovery (keyboard, mouse, gamepad) ---
# Non-balena base images do not auto-start udev; we must do it ourselves.
# Without a running udevd, Xorg cannot hotplug-discover input devices.
# In balena, io.balena.features.dbus mounts the socket at /run/dbus/system_bus_socket
# and sets DBUS_SYSTEM_BUS_ADDRESS automatically. However, if /run is a tmpfs the
# socket may be wiped. Verify the socket actually exists; start our own daemon if not.

_dbus_socket="/run/dbus/system_bus_socket"
_need_dbus=true

# _dbus_socket_alive: verify a D-Bus socket is actually responding, not just present on disk.
# A stale or bind-mounted socket file can exist without a listening daemon, causing Xorg to
# spam "dbus-core: error connecting to system bus" every 10 seconds.
_dbus_socket_alive() {
  local sock="$1"
  [[ -S "${sock}" ]] || return 1
  if command -v dbus-send >/dev/null 2>&1; then
    # Use GetId instead of Peer.Ping; the default system bus policy denies
    # Peer.Ping to the bus daemon itself, producing noisy "Rejected send" logs.
    DBUS_SYSTEM_BUS_ADDRESS="unix:path=${sock}" \
      dbus-send --system --dest=org.freedesktop.DBus --print-reply /org/freedesktop/DBus \
        org.freedesktop.DBus.GetId >/dev/null 2>&1
  else
    # No dbus-send available; fall back to file-type check only
    return 0
  fi
}

# Check if an existing dbus socket is reachable
if [[ -n "${DBUS_SYSTEM_BUS_ADDRESS:-}" ]]; then
  # Extract path from unix:path=... format
  _configured_socket="${DBUS_SYSTEM_BUS_ADDRESS#unix:path=}"
  if _dbus_socket_alive "${_configured_socket}"; then
    echo "[svc-esde] D-Bus system bus already available at ${_configured_socket}"
    _need_dbus=false
  else
    echo "[svc-esde] DBUS_SYSTEM_BUS_ADDRESS is set but socket ${_configured_socket} is not responding; will start our own." >&2
    unset DBUS_SYSTEM_BUS_ADDRESS
  fi
elif _dbus_socket_alive "${_dbus_socket}"; then
  export DBUS_SYSTEM_BUS_ADDRESS="unix:path=${_dbus_socket}"
  echo "[svc-esde] D-Bus system bus found at ${_dbus_socket}"
  _need_dbus=false
elif [[ -S "${_dbus_socket}" ]]; then
  echo "[svc-esde] D-Bus socket exists at ${_dbus_socket} but is not responding; will start our own." >&2
fi

if ${_need_dbus}; then
  if command -v dbus-daemon >/dev/null 2>&1; then
    if [[ ! -f /usr/share/dbus-1/system.conf ]]; then
      echo "[svc-esde] Warning: /usr/share/dbus-1/system.conf not found. Install 'dbus' package." >&2
      echo "[svc-esde]   Skipping dbus-daemon start; Xorg will log dbus-core errors (harmless but noisy)." >&2
    else
      if command -v dbus-uuidgen >/dev/null 2>&1; then
        dbus-uuidgen --ensure 2>/dev/null || true
      fi
      mkdir -p /run/dbus
      dbus-daemon --system --nofork --nopidfile 2>&1 | sed --unbuffered 's/^/[dbus] /' &
      # Wait for the socket to appear AND the daemon to respond to pings
      for _i in $(seq 1 50); do
        _dbus_socket_alive "${_dbus_socket}" && break
        sleep 0.1
      done
      if _dbus_socket_alive "${_dbus_socket}"; then
        export DBUS_SYSTEM_BUS_ADDRESS="unix:path=${_dbus_socket}"
        echo "[svc-esde] Started dbus-daemon; system bus available."
      else
        echo "[svc-esde] Warning: dbus-daemon started but not responding after 5s." >&2
      fi
    fi
  else
    echo "[svc-esde] Warning: dbus-daemon not installed. Xorg will log dbus-core errors." >&2
  fi
fi

# --- Video driver selection ---
# ESDE_VIDEO_DRIVER controls how ES-DE accesses the display:
#   kmsdrm  - Direct DRM/KMS (no X11). Best for SBCs like Raspberry Pi.
#   x11     - Start internal Xorg (legacy ESDE_USE_INTERNAL_X=1 path).
#   auto    - Auto-detect: prefer kmsdrm if /dev/dri/card0 exists.
# Falls through to external X11 socket if none of the above match.

# --- Raspberry Pi detection ---
# RPi4/5 uses a split-render DRM architecture: card0 = vc4 display controller
# (has HDMI connectors but cannot create GLES contexts), card1 = v3d GPU (does
# GLES 3.1 but has no display connectors). SDL2 KMSDRM opens card0 for its
# connectors, then tries to create an EGL/GLES context on it, which fails with
# EGL_BAD_MATCH because vc4 doesn't support context creation.
# KMSDRM will *never* work on RPi with this split architecture; X11 with the
# modesetting driver + glamor is the correct path.
_is_rpi=false
# Method 1: device-tree model string (most reliable, works in privileged containers)
if [[ -r /proc/device-tree/model ]]; then
  _dt_model="$(tr -d '\0' < /proc/device-tree/model 2>/dev/null)" || true
  if [[ "${_dt_model}" == *"Raspberry Pi"* ]]; then
    _is_rpi=true
    echo "[svc-esde] Detected Raspberry Pi hardware: ${_dt_model}"
  fi
fi
# Method 2: sysfs DRM driver name
if ! ${_is_rpi}; then
  for _card in /dev/dri/card*; do
    [[ -e "${_card}" ]] || continue
    _card_name="$(basename "${_card}")"
    _drv_link="/sys/class/drm/${_card_name}/device/driver"
    if [[ -L "${_drv_link}" ]]; then
      _drv_name="$(basename "$(readlink -f "${_drv_link}")")"
      if [[ "${_drv_name}" = "vc4-drm" || "${_drv_name}" = "vc4" ]]; then
        _is_rpi=true
        echo "[svc-esde] Detected vc4 DRM driver on ${_card_name} (Raspberry Pi)."
        break
      fi
    fi
  done
fi
# Method 3: ALSA card names containing "vc4hdmi" (available even without sysfs)
if ! ${_is_rpi} && [[ -r /proc/asound/cards ]]; then
  if grep -qi 'vc4hdmi\|vc4-hdmi' /proc/asound/cards 2>/dev/null; then
    _is_rpi=true
    echo "[svc-esde] Detected Raspberry Pi via ALSA card names (vc4-hdmi)."
  fi
fi

_video_driver="${ESDE_VIDEO_DRIVER:-auto}"

# On Raspberry Pi, force X11 — KMSDRM cannot work with the split vc4+v3d DRM.
if ${_is_rpi}; then
  if [[ "${_video_driver}" = "kmsdrm" ]]; then
    echo "[svc-esde] WARNING: ESDE_VIDEO_DRIVER=kmsdrm is set but Raspberry Pi vc4+v3d split-render"
    echo "[svc-esde]   architecture does not support KMSDRM (EGL_BAD_MATCH). Overriding to x11."
  fi
  _video_driver="x11"
fi

if [[ "${_video_driver}" = "auto" ]]; then
  if [[ "${ESDE_USE_INTERNAL_X:-0}" = "1" ]]; then
    _video_driver="x11"
  elif [[ -e /dev/dri/card0 ]]; then
    _video_driver="kmsdrm"
  fi
fi
echo "[svc-esde] Video driver selection: ESDE_VIDEO_DRIVER=${ESDE_VIDEO_DRIVER:-<unset>}, resolved to '${_video_driver}'"

if [[ "${_video_driver}" = "kmsdrm" ]]; then
  echo "[svc-esde] Using KMSDRM video driver (direct to display, no Xorg)."
  export SDL_VIDEODRIVER=kmsdrm

  # Force SDL2 to use EGL/GLES instead of desktop GL.
  # Required for GPUs that only expose GLES (e.g. Raspberry Pi V3D, Mali).
  export SDL_OPENGL_ES_DRIVER=1

  # Prevent SDL2 from falling back to X11 or being confused by X11 env vars.
  unset DISPLAY 2>/dev/null || true
  unset XAUTHORITY 2>/dev/null || true

  # Log DRM devices for diagnostics
  if [[ -d /dev/dri ]]; then
    echo "[svc-esde] DRM devices: $(ls /dev/dri/ 2>/dev/null | tr '\n' ' ')"
  else
    echo "[svc-esde] Error: /dev/dri not found. KMSDRM requires GPU passthrough." >&2
  fi

  # KMSDRM needs direct VT access; ensure we have a usable VT.
  # SDL2 will open /dev/tty and issue VT_* ioctls.
  if [[ ! -e /dev/tty0 ]]; then
    echo "[svc-esde] Warning: /dev/tty0 not found. KMSDRM may fail without VT access." >&2
    echo "[svc-esde]   Ensure the container runs with --privileged or has /dev/tty* access." >&2
  fi

  # Raspberry Pi split-render detection was already handled above;
  # if we reach here, KMSDRM should be viable for this GPU.

  # KMSDRM requires DRM master (drmSetMaster ioctl), which needs root or
  # CAP_SYS_ADMIN. s6-setuidgid drops all capabilities, so es-de must run
  # as root for KMSDRM. This is acceptable for a dedicated appliance container.
  # The es-de home directory still needs to be writable.
  chown -R "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}" 2>/dev/null || true

  start_log_tailers
  echo "[svc-esde] Launching ES-DE via KMSDRM as root (DRM master requires root/CAP_SYS_ADMIN)."
  # Temporarily disable errexit so the fallback to X11 can trigger on failure.
  set +eo pipefail
  /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  _kmsdrm_rc=${PIPESTATUS[0]}
  set -eo pipefail
  cleanup_log_tailers

  if [[ ${_kmsdrm_rc} -eq 0 ]]; then
    exit 0
  fi

  echo "[svc-esde] KMSDRM launch failed (exit code ${_kmsdrm_rc}). Falling back to X11 (Xorg)." >&2
  unset SDL_VIDEODRIVER SDL_OPENGL_ES_DRIVER
  export DISPLAY=":${display_num}"
  _video_driver="x11"
  # Fall through to X11 section below
fi

if [[ "${_video_driver}" = "x11" || "${ESDE_USE_INTERNAL_X:-0}" = "1" ]]; then
  echo "[svc-esde] Starting internal Xorg session via startx (as root for VT management)."

  # Clean stale X lock/socket files from a previous crash to prevent startx failure
  rm -f "/tmp/.X${display_num}-lock" 2>/dev/null || true
  rm -f "/tmp/.X11-unix/X${display_num}" 2>/dev/null || true

  sed -i -e 's/console/anybody/g' /etc/X11/Xwrapper.config || true
  if ! grep -q '^needs_root_rights=yes$' /etc/X11/Xwrapper.config 2>/dev/null; then
    echo 'needs_root_rights=yes' >> /etc/X11/Xwrapper.config
  fi
  export XAUTHORITY="${XAUTHORITY:-${XDG_RUNTIME_DIR}/.Xauthority}"
  touch "${XAUTHORITY}"
  chmod 600 "${XAUTHORITY}"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${XAUTHORITY}"
  if command -v mcookie >/dev/null 2>&1 && command -v xauth >/dev/null 2>&1; then
    cookie="$(mcookie)"
    xauth -f "${XAUTHORITY}" remove "${DISPLAY}" >/dev/null 2>&1 || true
    xauth -f "${XAUTHORITY}" add "${DISPLAY}" . "${cookie}" >/dev/null 2>&1 || true
  fi
  startx_server_args=("${DISPLAY}" -nolisten tcp -novtswitch -keeptty -nocursor -auth "${XAUTHORITY}")
  if [[ "${ESDE_XORG_VERBOSE:-0}" = "1" ]]; then
    startx_server_args+=( -verbose 3 )
  fi
  start_log_tailers
  # Xorg detailed output is already captured by the [Xorg] log tailer from the log file.
  # Filter startx output to only show non-Xorg messages (startx wrapper, xinit, errors).
  startx /usr/local/bin/esde-startx-session -- "${startx_server_args[@]}" 2>&1 \
    | grep -v --line-buffered -E '^\(([=-][=-]|[*][*]|\!\!|\?\?|II|WW|EE|NI)\)|^X\.Org X Server|^X Protocol Version|^Current Operating System|^Kernel command line|^xorg-server |^Current version of pixman|^[[:space:]]*(Before reporting|to make sure)|^Markers:|^[[:space:]]*\(' \
    | sed --unbuffered 's/^/[startx] /'
  exit ${PIPESTATUS[0]}
fi

if [[ ! -S /tmp/.X11-unix/X${DISPLAY#:} ]]; then
  echo "[svc-esde] X11 socket /tmp/.X11-unix/X${DISPLAY#:} is not available. Mount /tmp/.X11-unix from the host, set ESDE_VIDEO_DRIVER=x11, or set ESDE_VIDEO_DRIVER=kmsdrm." >&2
  sleep infinity
fi

start_log_tailers
if [[ -z ${LSIO_NON_ROOT_USER:-} ]]; then
  s6-setuidgid "${APP_USER}" /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  exit ${PIPESTATUS[0]}
else
  /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  exit ${PIPESTATUS[0]}
fi
