#!/usr/bin/with-contenv bash
set -euo pipefail

display_num="${DISPLAY_NUM:-0}"
export DISPLAY="${DISPLAY:-:${display_num}}"

if [[ -z ${XDG_RUNTIME_DIR:-} ]]; then
  echo "[svc-esde] Warning: XDG_RUNTIME_DIR not set. Setting to /run/esde" >&2
  export XDG_RUNTIME_DIR=/run/esde
fi

mkdir -p "${XDG_RUNTIME_DIR}"
chmod 700 "${XDG_RUNTIME_DIR}"
chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${XDG_RUNTIME_DIR}"

# --- Device group membership ---
# The abc user needs supplementary groups for GPU, audio, and input access.
# s6-setuidgid reads supplementary groups from /etc/group, so the user must
# be a member before we drop privileges.
app_user="${APP_USER:-abc}"
for grp in video render audio input; do
  if getent group "${grp}" >/dev/null 2>&1; then
    if ! id -nG "${app_user}" 2>/dev/null | grep -qw "${grp}"; then
      usermod -aG "${grp}" "${app_user}" 2>/dev/null || true
    fi
  fi
done

# Match host device GIDs for /dev/dri and /dev/snd if they differ from standard groups
if [[ -e /dev/dri/card0 ]]; then
  dri_gid="$(stat -c '%g' /dev/dri/card0 2>/dev/null)" || true
  if [[ -n "${dri_gid}" && "${dri_gid}" != "0" ]]; then
    if ! id -G "${app_user}" 2>/dev/null | grep -qw "${dri_gid}"; then
      # Create/reuse a group matching the host GID and add the user
      dri_grp="$(getent group "${dri_gid}" 2>/dev/null | cut -d: -f1)" || true
      if [[ -z "${dri_grp}" ]]; then
        groupadd -g "${dri_gid}" hostdri 2>/dev/null || true
        dri_grp="hostdri"
      fi
      usermod -aG "${dri_grp}" "${app_user}" 2>/dev/null || true
      echo "[svc-esde] Added ${app_user} to group ${dri_grp} (GID ${dri_gid}) for /dev/dri access."
    fi
  fi
fi

if [[ -e /dev/snd/controlC0 ]]; then
  snd_gid="$(stat -c '%g' /dev/snd/controlC0 2>/dev/null)" || true
  if [[ -n "${snd_gid}" && "${snd_gid}" != "0" ]]; then
    if ! id -G "${app_user}" 2>/dev/null | grep -qw "${snd_gid}"; then
      snd_grp="$(getent group "${snd_gid}" 2>/dev/null | cut -d: -f1)" || true
      if [[ -z "${snd_grp}" ]]; then
        groupadd -g "${snd_gid}" hostaudio 2>/dev/null || true
        snd_grp="hostaudio"
      fi
      usermod -aG "${snd_grp}" "${app_user}" 2>/dev/null || true
      echo "[svc-esde] Added ${app_user} to group ${snd_grp} (GID ${snd_gid}) for /dev/snd access."
    fi
  fi
fi

# Match host device GIDs for /dev/input (gamepads, keyboards, mice)
if [[ -d /dev/input ]]; then
  for _input_dev in /dev/input/event*; do
    [[ -e "${_input_dev}" ]] || continue
    input_gid="$(stat -c '%g' "${_input_dev}" 2>/dev/null)" || true
    if [[ -n "${input_gid}" && "${input_gid}" != "0" ]]; then
      if ! id -G "${app_user}" 2>/dev/null | grep -qw "${input_gid}"; then
        input_grp="$(getent group "${input_gid}" 2>/dev/null | cut -d: -f1)" || true
        if [[ -z "${input_grp}" ]]; then
          groupadd -g "${input_gid}" hostinput 2>/dev/null || true
          input_grp="hostinput"
        fi
        usermod -aG "${input_grp}" "${app_user}" 2>/dev/null || true
        echo "[svc-esde] Added ${app_user} to group ${input_grp} (GID ${input_gid}) for /dev/input access."
      fi
    fi
    break  # Only need to check one device for the GID
  done
fi

# --- Audio detection and setup ---
# ES-DE requires PulseAudio or PipeWire; raw ALSA is not supported.

# Load the USB audio kernel module if available. Without it, USB sound cards
# will not appear in /proc/asound/cards even when /dev/bus/usb is passed through.
if [[ -d /dev/bus/usb ]]; then
  modprobe snd-usb-audio 2>/dev/null || true
fi

# --- RPi detection (used for bcm2835 analog, HDMI hints, etc.) ---
_is_rpi=false
if [[ -e /proc/device-tree/model ]]; then
  _model="$(tr -d '\0' < /proc/device-tree/model 2>/dev/null)" || true
  [[ "${_model}" == *"Raspberry"* ]] && _is_rpi=true
elif grep -qi 'raspberry\|bcm27\|bcm28' /proc/cpuinfo 2>/dev/null; then
  _is_rpi=true
fi

# --- Audio output preference ---
# ESDE_AUDIO_OUTPUT selects audio output:
#   analog  — Force 3.5mm headphone jack (RPi only, requires dtparam=audio=on)
#   hdmi    — Force HDMI audio
#   usb     — Force USB audio device
#   auto    — Auto-detect: USB > analog > HDMI (default)
_audio_output="${ESDE_AUDIO_OUTPUT:-auto}"

# Load the bcm2835 audio module for Raspberry Pi 3.5mm analog output.
# On modern RPi kernels with vc4, this module is not loaded by default
# because the vc4 HDMI driver handles digital audio on its own.
# Without this module, the 3.5mm headphone jack will be invisible to ALSA.
_bcm2835_loaded=false
if ${_is_rpi}; then
  if modprobe snd_bcm2835 2>/dev/null; then
    # Module loaded — wait up to 5s for the ALSA card to appear
    for _bcm_wait in $(seq 1 10); do
      if grep -qi 'bcm2835\|Headphones' /proc/asound/cards 2>/dev/null; then
        _bcm2835_loaded=true
        break
      fi
      # Retrigger udev sound subsystem to pick up new card
      udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
      sleep 0.5
    done
  fi
  if ! ${_bcm2835_loaded}; then
    echo "[svc-esde] Warning: RPi 3.5mm analog audio NOT available." >&2
    echo "[svc-esde]   The snd_bcm2835 module did not create an ALSA card." >&2
    echo "[svc-esde]   To enable 3.5mm audio, set Balena device variable:" >&2
    echo "[svc-esde]     BALENA_HOST_CONFIG_dtparam = \"audio=on\"" >&2
    echo "[svc-esde]   Then reboot the device." >&2
  fi
else
  modprobe snd_bcm2835 2>/dev/null || true
fi

# --- Status summary variables (collected during setup, printed after ES-DE starts) ---
_summary_audio=""
_summary_sink=""
_summary_input=""
_summary_emulator=""

# Start udevd early so PulseAudio's module-udev-detect can discover ALSA cards,
# and Xorg can later discover input devices.
if ! pidof systemd-udevd >/dev/null 2>&1 && ! pidof udevd >/dev/null 2>&1; then
  if [[ -x /usr/lib/systemd/systemd-udevd ]]; then
    echo "[svc-esde] Starting udevd for device discovery."
    /usr/lib/systemd/systemd-udevd --daemon 2>/dev/null || true
    udevadm trigger --action=add 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
    # Retrigger USB sound and input subsystems — USB devices may need extra time
    udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=input 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
  elif command -v udevd >/dev/null 2>&1; then
    echo "[svc-esde] Starting udevd for device discovery."
    udevd --daemon 2>/dev/null || true
    udevadm trigger --action=add 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
    udevadm trigger --action=add --subsystem-match=input 2>/dev/null || true
    udevadm settle --timeout=5 2>/dev/null || true
  else
    echo "[svc-esde] Warning: udevd not found. Audio detection and input hotplug may not work." >&2
  fi
fi

# 1. Detect ALSA hardware (sound cards visible to the kernel)
if [[ -d /dev/snd ]]; then
  if [[ -r /proc/asound/cards ]]; then
    # Build compact card list for summary
    _alsa_cards="$(grep -E '^\s*[0-9]' /proc/asound/cards | sed 's/.*\]: //' | tr '\n' ', ' | sed 's/, $//')" || true
    _summary_audio="ALSA: ${_alsa_cards:-none}"
  else
    _summary_audio="ALSA: /dev/snd present, no cards"
  fi
else
  _summary_audio="ALSA: WARNING /dev/snd not found"
fi

# Check if USB audio devices are expected but missing.
# After modprobe + udev settle, USB audio cards may take several seconds to
# fully enumerate (chipset initialization, firmware load, etc.).
# Wait up to 15 seconds, retriggering udev periodically.
if [[ -d /dev/bus/usb ]]; then
  _usb_audio_found=false
  for _usb_wait in $(seq 1 15); do
    # Method 1: check /proc/asound/cards for USB-named cards
    if grep -qi 'usb' /proc/asound/cards 2>/dev/null; then
      _usb_audio_found=true; break
    fi
    # Method 2: check sysfs for cards on the USB subsystem
    # (catches devices whose ALSA name does not contain "USB")
    for _scard in /sys/class/sound/card*/device; do
      [[ -L "${_scard}" ]] || continue
      if [[ "$(basename "$(readlink -f "${_scard}/subsystem" 2>/dev/null)" 2>/dev/null)" == "usb" ]]; then
        _usb_audio_found=true; break 2
      fi
    done
    # Retrigger sound subsystem every 5s in case the device appeared late
    if (( _usb_wait % 5 == 0 )); then
      udevadm trigger --action=add --subsystem-match=sound 2>/dev/null || true
      udevadm settle --timeout=3 2>/dev/null || true
    fi
    sleep 1
  done

  if ${_usb_audio_found}; then
    _summary_audio="${_summary_audio} | USB audio: yes"
  else
    _summary_audio="${_summary_audio} | USB audio: not found (host needs: modprobe snd-usb-audio)"
  fi
fi

# 2. Start PulseAudio
if command -v pulseaudio >/dev/null 2>&1; then
  if ! s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    s6-setuidgid "${APP_USER:-abc}" pulseaudio --start --exit-idle-time=-1 --daemonize=yes 2>/dev/null || \
      echo "[svc-esde] Warning: PulseAudio failed to start. Audio may be unavailable." >&2
  fi

  # 3. Fix PulseAudio card profiles
  # bcm2835 often gets a "stereo-fallback" profile instead of "analog-stereo"
  # which doesn't route audio properly. Explicitly set the correct profile.
  if s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    if ${_bcm2835_loaded}; then
      # Find the PulseAudio card index for the bcm2835 device and set analog profile
      _bcm_card_index="$(s6-setuidgid "${APP_USER:-abc}" pactl list short cards 2>/dev/null \
        | grep -i 'bcm2835\|Headphones' | head -1 | awk '{print $1}')" || true
      if [[ -n "${_bcm_card_index}" ]]; then
        # Try output:analog-stereo first (PulseAudio 14+), fall back to analog-stereo
        s6-setuidgid "${APP_USER:-abc}" pactl set-card-profile "${_bcm_card_index}" output:analog-stereo 2>/dev/null || \
          s6-setuidgid "${APP_USER:-abc}" pactl set-card-profile "${_bcm_card_index}" analog-stereo 2>/dev/null || true
        # Give PA a moment to recreate sinks with the new profile
        sleep 1
      fi
    fi
  fi

  # 4. Configure default sink (wait for PulseAudio to discover devices)
  # USB audio devices can take several seconds to be discovered by
  # module-udev-detect.  Wait up to 20s for a hardware ALSA sink.
  if s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    _hw_sink=""
    for _wait in $(seq 1 20); do
      sink_list="$(s6-setuidgid "${APP_USER:-abc}" pactl list short sinks 2>/dev/null)" || true

      # Sink selection respects ESDE_AUDIO_OUTPUT preference
      # Note: bcm2835 can appear as "analog-stereo" OR "stereo-fallback"
      case "${_audio_output}" in
        analog)
          _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*\(analog\|stereo-fallback\)' | grep -iv 'hdmi' | head -1 | awk '{print $2}')" || true
          ;;
        hdmi)
          _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*hdmi' | head -1 | awk '{print $2}')" || true
          ;;
        usb)
          _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*usb' | head -1 | awk '{print $2}')" || true
          ;;
        *)
          # auto: Priority: 1) USB audio  2) 3.5mm analog  3) any ALSA (usually HDMI)
          _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*usb' | head -1 | awk '{print $2}')" || true
          if [[ -z "${_hw_sink}" ]]; then
            _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output.*\(analog\|stereo-fallback\)' | grep -iv 'hdmi' | head -1 | awk '{print $2}')" || true
          fi
          if [[ -z "${_hw_sink}" ]]; then
            _hw_sink="$(echo "${sink_list}" | grep -i 'alsa_output' | head -1 | awk '{print $2}')" || true
          fi
          ;;
      esac
      if [[ -n "${_hw_sink}" ]]; then
        break
      fi
      sleep 1
    done

    # Collect sink info for summary
    sink_list="$(s6-setuidgid "${APP_USER:-abc}" pactl list short sinks 2>/dev/null)" || true
    _sink_names="$(echo "${sink_list}" | awk '{print $2}' | tr '\n' ', ' | sed 's/,$//')" || true

    # Set default sink
    if [[ -n "${LOCAL_AUDIO_SINK:-}" ]]; then
      if s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${LOCAL_AUDIO_SINK}" 2>/dev/null; then
        _summary_sink="Sink: ${LOCAL_AUDIO_SINK} (manual)"
      else
        _summary_sink="Sink: FAILED to set ${LOCAL_AUDIO_SINK}"
      fi
    elif [[ -n "${_hw_sink}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${_hw_sink}" 2>/dev/null || true
      _summary_sink="Sink: ${_hw_sink}"
    elif [[ -n "${sink_list}" ]]; then
      default_sink="$(echo "${sink_list}" | head -1 | awk '{print $2}')" || true
      if [[ -n "${default_sink:-}" ]]; then
        s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${default_sink}" 2>/dev/null || true
        _summary_sink="Sink: ${default_sink} (auto)"
      fi
    else
      _summary_sink="Sink: NONE DETECTED"
    fi
    [[ -n "${_sink_names}" ]] && _summary_sink="${_summary_sink} | Available: ${_sink_names}"

    # --- Unmute and set volume on the active sink ---
    # PulseAudio sinks often default to muted or 0% volume, especially for
    # HDMI outputs. This is the most common cause of "no audio".
    _active_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
    if [[ -n "${_active_sink}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-sink-mute "${_active_sink}" 0 2>/dev/null || true
      s6-setuidgid "${APP_USER:-abc}" pactl set-sink-volume "${_active_sink}" 100% 2>/dev/null || true
      # Verify volume/mute status
      _vol="$(s6-setuidgid "${APP_USER:-abc}" pactl get-sink-volume "${_active_sink}" 2>/dev/null | grep -oP '[0-9]+%' | head -1)" || true
      _mute="$(s6-setuidgid "${APP_USER:-abc}" pactl get-sink-mute "${_active_sink}" 2>/dev/null | awk '{print $2}')" || true
      _summary_sink="${_summary_sink} | Vol: ${_vol:-?} Mute: ${_mute:-?}"
    fi

    # Unmute ALSA mixer controls for all sound cards.
    # HDMI audio on RPi vc4 can be muted at ALSA level independently of PulseAudio.
    if command -v amixer >/dev/null 2>&1 && [[ -r /proc/asound/cards ]]; then
      while read -r _cnum; do
        [[ "${_cnum}" =~ ^[0-9]+$ ]] || continue
        amixer -c "${_cnum}" sset 'PCM' 100% unmute 2>/dev/null || true
        amixer -c "${_cnum}" sset 'Master' 100% unmute 2>/dev/null || true
      done < <(grep -oP '^\s*\K[0-9]+' /proc/asound/cards 2>/dev/null)
    fi
  fi
else
  _summary_sink="Sink: PulseAudio NOT INSTALLED"
fi

if [[ ! -e /dev/dri/renderD128 && ! -e /dev/dri/card0 ]]; then
  _summary_audio="${_summary_audio} | WARNING: no /dev/dri GPU"
fi

# --- Read ES-DE audio settings from es_settings.xml and wire to PulseAudio ---
# ES-DE stores audio preferences in es_settings.xml after its first run.
# Key settings:
#   SystemVolume          (0-100)  — maps to PulseAudio master volume on Linux
#   AudioDevice           (string) — SDL2 device description, e.g. "Built-in Audio Digital Stereo (HDMI)"
#   SoundVolumeNavigation (0-100)  — internal to ES-DE
#   SoundVolumeVideos     (0-100)  — internal to ES-DE
# We read these and match AudioDevice to a PulseAudio sink, then set volume/unmute
# so the audio subsystem is ready before ES-DE launches.
_esde_settings=""
_esde_settings_home="${ESDE_HOME:-/config}"
for _settings_candidate in \
  "${_esde_settings_home}/ES-DE/settings/es_settings.xml" \
  "${_esde_settings_home}/.emulationstation-de/settings/es_settings.xml" \
  "${_esde_settings_home}/settings/es_settings.xml"; do
  if [[ -f "${_settings_candidate}" ]]; then
    _esde_settings="${_settings_candidate}"
    break
  fi
done

_summary_esde_audio=""
if [[ -n "${_esde_settings}" ]]; then
  # Parse SystemVolume (integer 0-100)
  _esde_vol="$(grep -oP 'name="SystemVolume"\s+value="\K[^"]+' "${_esde_settings}" 2>/dev/null)" || true
  # Parse AudioDevice (SDL2 device description string)
  _esde_audio_dev="$(grep -oP 'name="AudioDevice"\s+value="\K[^"]+' "${_esde_settings}" 2>/dev/null)" || true

  _summary_esde_audio="ES-DE: vol=${_esde_vol:-default} device=\"${_esde_audio_dev:-auto}\""

  # If ES-DE has no AudioDevice set (empty or missing), update the settings file
  # with the currently selected PulseAudio sink's description so ES-DE uses the
  # correct output device.
  if [[ -z "${_esde_audio_dev}" ]] && s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    _active_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
    if [[ -n "${_active_sink}" ]]; then
      _sink_desc="$(s6-setuidgid "${APP_USER:-abc}" pactl list sinks 2>/dev/null | awk -v sink="${_active_sink}" '
        /^\tName:/ { found=($2 == sink) }
        found && /^\tDescription:/ { sub(/^\tDescription: /, ""); print; exit }
      ')" || true
      if [[ -n "${_sink_desc}" ]]; then
        if grep -q 'name="AudioDevice"' "${_esde_settings}" 2>/dev/null; then
          # Update existing AudioDevice entry
          sed -i 's|name="AudioDevice" value="[^"]*"|name="AudioDevice" value="'"${_sink_desc}"'"|' "${_esde_settings}" 2>/dev/null || true
        else
          # Insert AudioDevice setting before closing tag or at end
          sed -i '/<\/[^>]*>$/i\<string name="AudioDevice" value="'"${_sink_desc}"'" />' "${_esde_settings}" 2>/dev/null || \
            echo '<string name="AudioDevice" value="'"${_sink_desc}"'" />' >> "${_esde_settings}" 2>/dev/null || true
        fi
        _esde_audio_dev="${_sink_desc}"
        _summary_esde_audio="ES-DE: vol=${_esde_vol:-default} device=\"${_esde_audio_dev}\" (auto-set)"
      fi
    fi
  fi

  # Map ES-DE's AudioDevice (SDL2 description) to a PulseAudio sink name.
  # SDL2's PulseAudio driver lists sinks by their description, not their name.
  # We query `pactl list sinks` and match the Description field.
  if [[ -n "${_esde_audio_dev}" ]] && s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    _matched_sink=""
    while IFS=$'\t' read -r _sink_name _sink_desc; do
      if [[ "${_sink_desc}" == "${_esde_audio_dev}" ]]; then
        _matched_sink="${_sink_name}"
        break
      fi
    done < <(s6-setuidgid "${APP_USER:-abc}" pactl list sinks 2>/dev/null | awk '
      /^\tName:/ { name=$2 }
      /^\tDescription:/ { sub(/^\tDescription: /, ""); print name "\t" $0 }
    ')

    if [[ -n "${_matched_sink}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-default-sink "${_matched_sink}" 2>/dev/null || true
      _summary_esde_audio="${_summary_esde_audio} -> sink=${_matched_sink}"
    else
      _summary_esde_audio="${_summary_esde_audio} (device not found in PA sinks)"
    fi
  fi

  # Apply ES-DE's SystemVolume to the PulseAudio default sink.
  # ES-DE does this itself via SDL on startup, but ensuring it's pre-set avoids
  # a window where audio plays at 0% or muted before ES-DE finishes initializing.
  if [[ -n "${_esde_vol}" && "${_esde_vol}" =~ ^[0-9]+$ ]] && \
     s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    _active_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
    if [[ -n "${_active_sink}" ]]; then
      s6-setuidgid "${APP_USER:-abc}" pactl set-sink-mute "${_active_sink}" 0 2>/dev/null || true
      s6-setuidgid "${APP_USER:-abc}" pactl set-sink-volume "${_active_sink}" "${_esde_vol}%" 2>/dev/null || true
    fi
  fi
else
  # First boot — no es_settings.xml yet. ES-DE will create it with defaults.
  # Seed a minimal settings file with the correct AudioDevice so ES-DE picks
  # the right output on first launch instead of potentially choosing a dummy sink.
  if s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
    _active_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
    if [[ -n "${_active_sink}" ]]; then
      # Get the PulseAudio sink description (this is what SDL2 uses as the device name)
      _sink_description=""
      _sink_description="$(s6-setuidgid "${APP_USER:-abc}" pactl list sinks 2>/dev/null | awk -v sink="${_active_sink}" '
        /^\tName:/ { found=($2 == sink) }
        found && /^\tDescription:/ { sub(/^\tDescription: /, ""); print; exit }
      ')" || true

      if [[ -n "${_sink_description}" ]]; then
        # Create ES-DE settings directory and seed audio config
        _esde_settings_dir="${_esde_settings_home}/ES-DE/settings"
        mkdir -p "${_esde_settings_dir}"
        chown -R "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_settings_home}/ES-DE" 2>/dev/null || true
        _esde_settings="${_esde_settings_dir}/es_settings.xml"
        if [[ ! -f "${_esde_settings}" ]]; then
          printf '%s\n' \
            '<?xml version="1.0"?>' \
            "<string name=\"AudioDevice\" value=\"${_sink_description}\" />" \
            '<int name="SystemVolume" value="100" />' \
            '<bool name="NavigationSoundsEnabled" value="true" />' \
            '<int name="SoundVolumeNavigation" value="70" />' \
            '<int name="SoundVolumeVideos" value="80" />' \
            > "${_esde_settings}"
          chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_settings}"
          _summary_esde_audio="ES-DE: seeded settings (device=\"${_sink_description}\" vol=100)"
        fi
      fi
    fi
  fi
  [[ -z "${_summary_esde_audio}" ]] && _summary_esde_audio="ES-DE: no settings file (first boot)"
fi

# --- Audio device wake ---
# Send a brief silence burst to force the ALSA device open. This is needed for:
#   - HDMI: triggers ELD/EDID audio handshake with the display
#   - bcm2835 analog: forces the PWM audio driver to initialize
# Without this, some outputs won't produce sound until audio data flows.
if s6-setuidgid "${APP_USER:-abc}" pulseaudio --check 2>/dev/null; then
  _active_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
  if [[ -n "${_active_sink}" && "${_active_sink}" == alsa_output* ]]; then
    # Extract ALSA card number from the sink name
    # Sink names like "alsa_output.1.hdmi-stereo" or "alsa_output.0.analog-stereo" -> card number
    _alsa_card="$(echo "${_active_sink}" | grep -oP 'alsa_output\.\K[0-9]+')" || true
    if [[ -n "${_alsa_card}" ]] && command -v speaker-test >/dev/null 2>&1; then
      timeout 2 speaker-test -D "plughw:${_alsa_card},0" -t sine -f 0 -l 1 >/dev/null 2>&1 || true
    elif [[ -n "${_alsa_card}" ]] && command -v aplay >/dev/null 2>&1; then
      dd if=/dev/zero bs=1 count=8000 2>/dev/null | \
        aplay -D "plughw:${_alsa_card},0" -r 8000 -f S16_LE -c 2 -q 2>/dev/null || true
    fi
  fi
fi

# --- Gamepad / input device diagnostics ---
if [[ -d /dev/input ]]; then
  _js_devs="$(ls /dev/input/js* 2>/dev/null)" || true
  _ev_devs="$(ls /dev/input/event* 2>/dev/null)" || true
  _js_count="$(echo "${_js_devs}" | grep -c . 2>/dev/null)" || _js_count=0
  _ev_count="$(echo "${_ev_devs}" | grep -c . 2>/dev/null)" || _ev_count=0
  [[ -z "${_js_devs}" ]] && _js_count=0
  [[ -z "${_ev_devs}" ]] && _ev_count=0
  # Compact: list all gamepads
  _gamepad_names=""
  for _js in /dev/input/js*; do
    [[ -e "${_js}" ]] || continue
    _js_base="$(basename "${_js}")"
    _js_name="$(cat "/sys/class/input/${_js_base}/device/name" 2>/dev/null)" || true
    [[ -n "${_js_name}" ]] && _gamepad_names="${_gamepad_names:+${_gamepad_names}, }${_js_name}"
  done
  _summary_input="Input: ${_ev_count} events, ${_js_count} joysticks"
  [[ -n "${_gamepad_names}" ]] && _summary_input="${_summary_input} [${_gamepad_names}]"
  # Verify the app user can read at least one event device (required by SDL2)
  for _ev in /dev/input/event*; do
    [[ -e "${_ev}" ]] || continue
    if ! s6-setuidgid "${APP_USER:-abc}" test -r "${_ev}" 2>/dev/null; then
      _summary_input="${_summary_input} | WARNING: permission denied on ${_ev}"
    fi
    break
  done
  # --- SDL2 GameController auto-mapping for unmapped joysticks ---
  # SDL2's GameController API requires a known button mapping to open a device.
  # Without one, gamepads (e.g. DragonRise "Generic USB Joystick") are invisible
  # to ES-DE.  We load the community DB (~3000 mappings) and auto-generate
  # generic fallback mappings for anything still unrecognised.
  if [[ ${_js_count} -gt 0 ]]; then
    _gcdb="/usr/local/share/es-de/gamecontrollerdb.txt"
    _gcdb_runtime="/tmp/gamecontrollerdb.txt"
    # Start with the community database
    if [[ -f "${_gcdb}" ]]; then
      cp "${_gcdb}" "${_gcdb_runtime}"
    else
      touch "${_gcdb_runtime}"
    fi
    # Auto-generate mappings for joysticks not in the community DB
    _auto_map_count=0
    if [[ -x /usr/local/bin/esde-gamepad-map ]]; then
      _map_log="/tmp/gamepad-map.log"
      _map_out="$(/usr/local/bin/esde-gamepad-map "${_gcdb_runtime}" 2>"${_map_log}")" || true
      if [[ -n "${_map_out}" ]]; then
        echo "${_map_out}" >> "${_gcdb_runtime}"
        _auto_map_count="$(echo "${_map_out}" | wc -l)"
      fi
      # Relay diagnostic output
      while IFS= read -r _map_line; do
        echo "[svc-esde] ${_map_line}"
      done < "${_map_log}" 2>/dev/null || true
    fi
    # SDL_GAMECONTROLLERCONFIG_FILE loads the merged DB+auto-generated mappings.
    # User-provided SDL_GAMECONTROLLERCONFIG (env var) takes highest priority.
    export SDL_GAMECONTROLLERCONFIG_FILE="${_gcdb_runtime}"
    if [[ ${_auto_map_count} -gt 0 ]]; then
      _summary_input="${_summary_input} | ${_auto_map_count} gamepad(s) auto-mapped"
    fi
    if [[ -n "${SDL_GAMECONTROLLERCONFIG:-}" ]]; then
      _summary_input="${_summary_input} | user SDL_GAMECONTROLLERCONFIG set"
    fi
  fi
else
  _summary_input="Input: WARNING /dev/input not found"
fi

# --- Emulator backend detection ---
# ES-DE is a frontend only; it shells out to emulators (usually RetroArch).
# Without an emulator, game launch will fail with:
#   Error: %EMULATOR_RETROARCH% ... not found
#
# Supported RetroArch: https://docs.linuxserver.io/images/docker-retroarch/
#
# Emulators are provided via the sidecar volume at /emulators/<name>
# (esde-emulator-provider).  Start with --profile sidecar.

_emulators_home="/emulators"
_esde_emuwrap="/usr/local/bin/esde-emuwrap"

# Scan for sidecar-provisioned emulators and set up PATH integration
if [[ -d "${_emulators_home}" ]]; then
  _found_any=false
  for _emu_dir in "${_emulators_home}"/*/; do
    [[ -d "${_emu_dir}" ]] || continue
    _emu_name="$(basename "${_emu_dir}")"
    _emu_bin="${_emu_dir}bin/${_emu_name}"
    if [[ -x "${_emu_bin}" ]] && ! command -v "${_emu_name}" >/dev/null 2>&1; then
      # Symlink generic wrapper as the emulator name on PATH
      if [[ -x "${_esde_emuwrap}" ]]; then
        ln -sf "${_esde_emuwrap}" "/usr/local/bin/${_emu_name}"
      else
        ln -sf "${_emu_bin}" "/usr/local/bin/${_emu_name}"
      fi
      _found_any=true
    fi
  done

  # Handle empty volume (sidecar hasn't run) — noted in summary only
  if ! ${_found_any} && [[ "$(find "${_emulators_home}" -maxdepth 0 -empty 2>/dev/null)" ]]; then
    _summary_emulator="Emulator: /emulators empty (sidecar not run)"
  fi
fi

# RetroArch-specific: link cores directory into standard search path
_ra_sidecar="${_emulators_home}/retroarch"
if [[ -d "${_ra_sidecar}/cores" ]]; then
  ln -sfn "${_ra_sidecar}/cores" /usr/lib/libretro 2>/dev/null || true
fi

# Check RetroArch status (primary emulator for ES-DE)
if command -v retroarch >/dev/null 2>&1; then
  _ra_source="installed"
  if [[ -x "${_ra_sidecar}/bin/retroarch" ]]; then
    _ra_source="sidecar"
  fi
  _ra_ver="$(retroarch --version 2>&1 | head -1)" || _ra_ver="unknown"
  _summary_emulator="Emulator: RetroArch (${_ra_source}) ${_ra_ver}"
  # Check for libretro cores
  _core_dirs=(/usr/lib/libretro /usr/lib/*/libretro "${_ra_sidecar}/cores" "${ESDE_HOME:-/config}/.config/retroarch/cores")
  _core_count=0
  for _cdir in "${_core_dirs[@]}"; do
    if [[ -d "${_cdir}" ]]; then
      _n="$(find "${_cdir}" -maxdepth 1 -name '*.so' 2>/dev/null | wc -l)"
      _core_count=$((_core_count + _n))
    fi
  done
  if [[ ${_core_count} -gt 0 ]]; then
    _core_names=""
    for _cdir in "${_core_dirs[@]}"; do
      [[ -d "${_cdir}" ]] || continue
      for _core_file in "${_cdir}"/*.so; do
        [[ -f "${_core_file}" ]] || continue
        _core_names="${_core_names:+${_core_names}, }$(basename "${_core_file}" .so)"
      done
    done
    _summary_emulator="${_summary_emulator} | ${_core_count} cores: ${_core_names}"
  else
    _summary_emulator="${_summary_emulator} | WARNING: no libretro cores"
  fi
else
  _summary_emulator="Emulator: WARNING RetroArch NOT installed — games will fail"
fi

esde_home="${ESDE_HOME:-/config}"
read -r -a extra_args <<< "${ESDE_ARGS:-}"

# Ensure the ES-DE home directory is writable by the application user
# so ES-DE can create subdirectories such as ROMs, gamelists, etc.
if [[ -d "${esde_home}" ]]; then
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}" 2>/dev/null || true
fi

# --- Symlink external volume mounts into ES-DE's expected paths ---
# docker-compose mounts /roms and /bios as named volumes, but ES-DE expects
# ROMs under ${ESDE_HOME}/ROMs and BIOS files in emulator-specific paths.
# Create symlinks so both locations work seamlessly.
if [[ -d /roms && ! -e "${esde_home}/ROMs" ]]; then
  ln -s /roms "${esde_home}/ROMs"
  chown -h "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/ROMs"
fi
if [[ -d /bios && ! -e "${esde_home}/.emulationstation/bios" ]]; then
  mkdir -p "${esde_home}/.emulationstation"
  ln -s /bios "${esde_home}/.emulationstation/bios"
  chown -h "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/.emulationstation" "${esde_home}/.emulationstation/bios"
fi

# --- Seed bundled demo ROMs on first boot ---
# /defaults/roms/ ships with the image and contains freely-licensed homebrew.
# Seed into ES-DE's actual ROM directory so ROMs are found regardless of
# whether /roms is mounted or /config/ROMs is a symlink vs real directory.
_esde_roms="${esde_home}/ROMs"
if [[ -d /defaults/roms ]]; then
  mkdir -p "${_esde_roms}"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_roms}" 2>/dev/null || true
  _rom_file_count="$(find "${_esde_roms}" -mindepth 1 -maxdepth 2 -type f \( -name '*.gb' -o -name '*.gbc' -o -name '*.nes' -o -name '*.sfc' -o -name '*.smc' -o -name '*.bin' -o -name '*.zip' -o -name '*.7z' \) 2>/dev/null | wc -l)"
  if [[ "${_rom_file_count}" -eq 0 ]]; then
    cp -rn /defaults/roms/* "${_esde_roms}/" 2>/dev/null || true
    chown -R "${APP_USER:-abc}":"${APP_USER:-abc}" "${_esde_roms}/" 2>/dev/null || true
  fi
fi

# --- Pre-create ROM directory structure ---
# ES-DE shows a first-run "create directories?" wizard when the ROMs directory
# has no system subdirectories. After the user clicks "create", ES-DE loops back
# to the same wizard because there are still 0 games. Pre-creating the structure
# avoids this; ES-DE will instead show the normal empty-gamelist screen.
_roms_dir="${esde_home}/ROMs"
if [[ -d "${_roms_dir}" ]]; then
  _subdir_count="$(find "${_roms_dir}" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)"
  if [[ "${_subdir_count}" -eq 0 ]]; then
    if s6-setuidgid "${APP_USER:-abc}" /usr/local/bin/es-de --create-system-dirs --home "${esde_home}" >/dev/null 2>&1; then
      true  # success, silent
    else
      true  # non-critical, ES-DE will prompt on first launch
    fi
  fi
fi

# --- Log forwarding to stdout (for balena / docker logs) ---
# ES-DE and Xorg write to files, not stdout. Tail them in the background
# so their output appears in `balena logs` / `docker logs`.
_log_pids=()
start_log_tailers() {
  local xorg_log="/var/log/Xorg.${display_num}.log"

  # Ensure the ES-DE log directory exists so tail -F can watch for creation
  mkdir -p "${esde_home}/logs"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}/logs"

  # ES-DE may write its log to different paths depending on version and config.
  # Search known locations; fall back to the standard path for tail -F to watch.
  local esde_log=""
  local -a esde_log_candidates=(
    "${esde_home}/logs/es_log.txt"
    "${esde_home}/.emulationstation-de/es_log.txt"
    "${esde_home}/ES-DE/logs/es_log.txt"
    "${esde_home}/es_log.txt"
  )
  for _candidate in "${esde_log_candidates[@]}"; do
    if [[ -f "${_candidate}" ]]; then
      esde_log="${_candidate}"
      break
    fi
  done
  # If no existing log file found, watch the standard path for creation
  esde_log="${esde_log:-${esde_log_candidates[0]}}"

  # RetroArch log (primary emulator backend) — so game-launch output appears in docker logs
  local ra_log="${esde_home}/.config/retroarch/logs/retroarch.log"
  mkdir -p "$(dirname "${ra_log}")" 2>/dev/null || true
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "$(dirname "${ra_log}")" 2>/dev/null || true

  # Use -n 0 to skip existing content and only show new lines from this session
  tail -n 0 -F "${esde_log}" 2>/dev/null | sed --unbuffered 's/^/[es-de] /' &
  _log_pids+=("$!")
  tail -n 0 -F "${xorg_log}" 2>/dev/null | sed --unbuffered 's/^/[Xorg] /' &
  _log_pids+=("$!")
  tail -n 0 -F "${ra_log}" 2>/dev/null | sed --unbuffered 's/^/[retroarch] /' &
  _log_pids+=("$!")
}

cleanup_log_tailers() {
  for pid in "${_log_pids[@]}"; do
    kill "${pid}" 2>/dev/null || true
  done
  jobs -p 2>/dev/null | xargs -r kill 2>/dev/null || true
}
trap cleanup_log_tailers EXIT

# --- Delayed startup summary ---
# Balena's log rate limiter suppresses rapid-fire output during setup.
# By waiting a few seconds after ES-DE starts, the summary arrives after
# the rate limiter window has passed and will always be visible.
emit_startup_summary() {
  sleep 8  # Wait for ES-DE's ~3.5s startup + rate limiter cooldown
  echo ""
  echo "[svc-esde] ═══════════════ STARTUP SUMMARY ═══════════════"
  echo "[svc-esde] ${_summary_audio}"
  echo "[svc-esde] ${_summary_sink}"
  echo "[svc-esde] ${_summary_input}"
  echo "[svc-esde] ${_summary_emulator}"
  echo "[svc-esde] ${_summary_esde_audio}"
  echo "[svc-esde] Audio output: ${_audio_output} (ESDE_AUDIO_OUTPUT=${ESDE_AUDIO_OUTPUT:-<unset>})"
  echo "[svc-esde] Video: ${_video_driver} (ESDE_VIDEO_DRIVER=${ESDE_VIDEO_DRIVER:-<unset>})"
  echo "[svc-esde] Tailing: es_log.txt, Xorg.log, retroarch.log"
  echo "[svc-esde] ES-DE is idle at menu — logs appear on activity (input config, game launch, errors)"
  # Actionable hints based on detected state
  if [[ "${_is_rpi}" == "true" ]]; then
    if [[ "${_audio_output}" == "analog" || "${_audio_output}" == "auto" ]] && ! ${_bcm2835_loaded}; then
      echo "[svc-esde] ⚠ 3.5mm audio: bcm2835 not loaded! Set Balena device var:"
      echo "[svc-esde]   BALENA_HOST_CONFIG_dtparam = \"audio=on\""
      echo "[svc-esde]   Then reboot the device."
    fi
    _chosen_sink="$(s6-setuidgid "${APP_USER:-abc}" pactl get-default-sink 2>/dev/null)" || true
    if [[ "${_chosen_sink}" == *"hdmi"* ]]; then
      echo "[svc-esde] No HDMI audio? Set Balena device var BALENA_HOST_CONFIG_hdmi_drive=2"
    fi
  fi
  echo "[svc-esde] ═══════════════════════════════════════════════"
  echo ""
}

# --- udev setup for input device discovery (keyboard, mouse, gamepad) ---
# Non-balena base images do not auto-start udev; we must do it ourselves.
# Without a running udevd, Xorg cannot hotplug-discover input devices.
# In balena, io.balena.features.dbus mounts the socket at /run/dbus/system_bus_socket
# and sets DBUS_SYSTEM_BUS_ADDRESS automatically. However, if /run is a tmpfs the
# socket may be wiped. Verify the socket actually exists; start our own daemon if not.

_dbus_socket="/run/dbus/system_bus_socket"
_need_dbus=true

# _dbus_socket_alive: verify a D-Bus socket is actually responding, not just present on disk.
# A stale or bind-mounted socket file can exist without a listening daemon, causing Xorg to
# spam "dbus-core: error connecting to system bus" every 10 seconds.
_dbus_socket_alive() {
  local sock="$1"
  [[ -S "${sock}" ]] || return 1
  if command -v dbus-send >/dev/null 2>&1; then
    # Use GetId instead of Peer.Ping; the default system bus policy denies
    # Peer.Ping to the bus daemon itself, producing noisy "Rejected send" logs.
    DBUS_SYSTEM_BUS_ADDRESS="unix:path=${sock}" \
      dbus-send --system --dest=org.freedesktop.DBus --print-reply /org/freedesktop/DBus \
        org.freedesktop.DBus.GetId >/dev/null 2>&1
  else
    # No dbus-send available; fall back to file-type check only
    return 0
  fi
}

# Check if an existing dbus socket is reachable
if [[ -n "${DBUS_SYSTEM_BUS_ADDRESS:-}" ]]; then
  # Extract path from unix:path=... format
  _configured_socket="${DBUS_SYSTEM_BUS_ADDRESS#unix:path=}"
  if _dbus_socket_alive "${_configured_socket}"; then
    _need_dbus=false
  else
    echo "[svc-esde] D-Bus at ${_configured_socket} not responding; starting our own." >&2
    unset DBUS_SYSTEM_BUS_ADDRESS
  fi
elif _dbus_socket_alive "${_dbus_socket}"; then
  export DBUS_SYSTEM_BUS_ADDRESS="unix:path=${_dbus_socket}"
  _need_dbus=false
elif [[ -S "${_dbus_socket}" ]]; then
  echo "[svc-esde] D-Bus socket at ${_dbus_socket} not responding; starting our own." >&2
fi

if ${_need_dbus}; then
  if command -v dbus-daemon >/dev/null 2>&1; then
    if [[ ! -f /usr/share/dbus-1/system.conf ]]; then
      echo "[svc-esde] Warning: dbus system.conf not found — Xorg will log dbus-core errors (harmless)." >&2
    else
      if command -v dbus-uuidgen >/dev/null 2>&1; then
        dbus-uuidgen --ensure 2>/dev/null || true
      fi
      mkdir -p /run/dbus
      dbus-daemon --system --nofork --nopidfile 2>&1 | sed --unbuffered 's/^/[dbus] /' &
      # Wait for the socket to appear AND the daemon to respond to pings
      for _i in $(seq 1 50); do
        _dbus_socket_alive "${_dbus_socket}" && break
        sleep 0.1
      done
      if _dbus_socket_alive "${_dbus_socket}"; then
        export DBUS_SYSTEM_BUS_ADDRESS="unix:path=${_dbus_socket}"
        echo "[svc-esde] D-Bus system bus available."
      else
        echo "[svc-esde] Warning: dbus-daemon not responding after 5s." >&2
      fi
    fi
  else
    echo "[svc-esde] Warning: dbus-daemon not installed. Xorg will log dbus-core errors." >&2
  fi
fi

# --- Video driver selection ---
# ESDE_VIDEO_DRIVER controls how ES-DE accesses the display:
#   kmsdrm  - Direct DRM/KMS (no X11). Best for SBCs like Raspberry Pi.
#   x11     - Start internal Xorg (legacy ESDE_USE_INTERNAL_X=1 path).
#   auto    - Auto-detect: prefer kmsdrm if /dev/dri/card0 exists.
# Falls through to external X11 socket if none of the above match.

# --- Raspberry Pi detection ---
# RPi4/5 uses a split-render DRM architecture: card0 = vc4 display controller
# (has HDMI connectors but cannot create GLES contexts), card1 = v3d GPU (does
# GLES 3.1 but has no display connectors). SDL2 KMSDRM opens card0 for its
# connectors, then tries to create an EGL/GLES context on it, which fails with
# EGL_BAD_MATCH because vc4 doesn't support context creation.
# KMSDRM will *never* work on RPi with this split architecture; X11 with the
# modesetting driver + glamor is the correct path.
# (_is_rpi was already detected at the top of the script for audio setup)
${_is_rpi} && _summary_audio="${_summary_audio} | RPi detected"
${_bcm2835_loaded} && _summary_audio="${_summary_audio} | bcm2835: loaded"
${_is_rpi} && ! ${_bcm2835_loaded} && _summary_audio="${_summary_audio} | bcm2835: NOT loaded (no 3.5mm)"

# On RPi, if HDMI negotiates DVI mode (no audio), PulseAudio will have the sink
# but audio won't play. Check EDID/status via DRM and note in summary.
if ${_is_rpi}; then
  _hdmi_audio_hint=""
  for _conn in /sys/class/drm/card*-HDMI-A-*/status; do
    [[ -f "${_conn}" ]] || continue
    _conn_status="$(cat "${_conn}" 2>/dev/null)" || true
    _conn_name="$(basename "$(dirname "${_conn}")")"
    if [[ "${_conn_status}" == "connected" ]]; then
      _hdmi_audio_hint="${_hdmi_audio_hint:+${_hdmi_audio_hint}, }${_conn_name}=connected"
    fi
  done
  if [[ -n "${_hdmi_audio_hint}" ]]; then
    _summary_audio="${_summary_audio} | DRM: ${_hdmi_audio_hint}"
  fi
  # If no audio after unmuting, the HDMI port may be in DVI mode (no audio channel).
  # Fix on Balena: set device variable BALENA_HOST_CONFIG_hdmi_drive=2
  # Fix on Raspberry Pi OS: add hdmi_drive=2 to /boot/config.txt
fi

_video_driver="${ESDE_VIDEO_DRIVER:-auto}"

# On Raspberry Pi, force X11 — KMSDRM cannot work with the split vc4+v3d DRM.
if ${_is_rpi}; then
  _video_driver="x11"
fi

if [[ "${_video_driver}" = "auto" ]]; then
  if [[ "${ESDE_USE_INTERNAL_X:-0}" = "1" ]]; then
    _video_driver="x11"
  elif [[ -e /dev/dri/card0 ]]; then
    _video_driver="kmsdrm"
  fi
fi
echo "[svc-esde] Video driver: ${_video_driver}"

if [[ "${_video_driver}" = "kmsdrm" ]]; then
  export SDL_VIDEODRIVER=kmsdrm
  export SDL_OPENGL_ES_DRIVER=1
  unset DISPLAY 2>/dev/null || true
  unset XAUTHORITY 2>/dev/null || true

  if [[ ! -d /dev/dri ]]; then
    echo "[svc-esde] Error: /dev/dri not found. KMSDRM requires GPU passthrough." >&2
  fi
  if [[ ! -e /dev/tty0 ]]; then
    echo "[svc-esde] Warning: /dev/tty0 not found — KMSDRM may fail without VT access." >&2
  fi

  # Raspberry Pi split-render detection was already handled above;
  # if we reach here, KMSDRM should be viable for this GPU.

  # KMSDRM requires DRM master (drmSetMaster ioctl), which needs root or
  # CAP_SYS_ADMIN. s6-setuidgid drops all capabilities, so es-de must run
  # as root for KMSDRM. This is acceptable for a dedicated appliance container.
  # The es-de home directory still needs to be writable.
  chown -R "${APP_USER:-abc}":"${APP_USER:-abc}" "${esde_home}" 2>/dev/null || true

  start_log_tailers
  emit_startup_summary &
  # Temporarily disable errexit so the fallback to X11 can trigger on failure.
  set +eo pipefail
  /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  _kmsdrm_rc=${PIPESTATUS[0]}
  set -eo pipefail
  cleanup_log_tailers

  if [[ ${_kmsdrm_rc} -eq 0 ]]; then
    exit 0
  fi

  echo "[svc-esde] KMSDRM launch failed (exit code ${_kmsdrm_rc}). Falling back to X11 (Xorg)." >&2
  unset SDL_VIDEODRIVER SDL_OPENGL_ES_DRIVER
  export DISPLAY=":${display_num}"
  _video_driver="x11"
  # Fall through to X11 section below
fi

if [[ "${_video_driver}" = "x11" || "${ESDE_USE_INTERNAL_X:-0}" = "1" ]]; then

  # Clean stale X lock/socket files from a previous crash to prevent startx failure
  rm -f "/tmp/.X${display_num}-lock" 2>/dev/null || true
  rm -f "/tmp/.X11-unix/X${display_num}" 2>/dev/null || true

  sed -i -e 's/console/anybody/g' /etc/X11/Xwrapper.config || true
  if ! grep -q '^needs_root_rights=yes$' /etc/X11/Xwrapper.config 2>/dev/null; then
    echo 'needs_root_rights=yes' >> /etc/X11/Xwrapper.config
  fi
  export XAUTHORITY="${XAUTHORITY:-${XDG_RUNTIME_DIR}/.Xauthority}"
  touch "${XAUTHORITY}"
  chmod 600 "${XAUTHORITY}"
  chown "${APP_USER:-abc}":"${APP_USER:-abc}" "${XAUTHORITY}"
  if command -v mcookie >/dev/null 2>&1 && command -v xauth >/dev/null 2>&1; then
    cookie="$(mcookie)"
    xauth -f "${XAUTHORITY}" remove "${DISPLAY}" >/dev/null 2>&1 || true
    xauth -f "${XAUTHORITY}" add "${DISPLAY}" . "${cookie}" >/dev/null 2>&1 || true
  fi
  startx_server_args=("${DISPLAY}" -nolisten tcp -novtswitch -keeptty -nocursor -auth "${XAUTHORITY}")
  if [[ "${ESDE_XORG_VERBOSE:-0}" = "1" ]]; then
    startx_server_args+=( -verbose 3 )
  fi
  start_log_tailers
  emit_startup_summary &
  # Xorg detailed output is already captured by the [Xorg] log tailer from the log file.
  # Filter startx output to only show non-Xorg messages (startx wrapper, xinit, errors).
  startx /usr/local/bin/esde-startx-session -- "${startx_server_args[@]}" 2>&1 \
    | grep -v --line-buffered -E '^\(([=-][=-]|[*][*]|\!\!|\?\?|II|WW|EE|NI)\)|^X\.Org X Server|^X Protocol Version|^Current Operating System|^Kernel command line|^xorg-server |^Current version of pixman|^[[:space:]]*(Before reporting|to make sure)|^Markers:|^[[:space:]]*\(' \
    | sed --unbuffered 's/^/[startx] /'
  exit ${PIPESTATUS[0]}
fi

if [[ ! -S /tmp/.X11-unix/X${DISPLAY#:} ]]; then
  echo "[svc-esde] X11 socket /tmp/.X11-unix/X${DISPLAY#:} is not available. Mount /tmp/.X11-unix from the host, set ESDE_VIDEO_DRIVER=x11, or set ESDE_VIDEO_DRIVER=kmsdrm." >&2
  sleep infinity
fi

start_log_tailers
emit_startup_summary &
if [[ -z ${LSIO_NON_ROOT_USER:-} ]]; then
  s6-setuidgid "${APP_USER}" /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  exit ${PIPESTATUS[0]}
else
  /usr/local/bin/es-de --home "${esde_home}" "${extra_args[@]}" 2>&1 | sed --unbuffered 's/^/[es-de] /'
  exit ${PIPESTATUS[0]}
fi
